+                    if status_code == 200:
+                        data = await response.json()
+
+                        # Track credit usage
+                        _firecrawl_track_credit()
+
+                        # Validate response success field
+                        if isinstance(data, dict) and not data.get("success", True):
+                            error_msg = data.get("error", "Unknown error")
