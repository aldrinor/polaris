+    extra = os.getenv("PG_PAYWALL_PUBLISHER_HOSTS", "").strip()
+    if extra:
+        hosts.extend(h.strip().lower() for h in extra.split(",") if h.strip())
+    return any(h in netloc for h in hosts)
