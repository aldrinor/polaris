 succeeded in 1082ms:
    1: """M-35 (2026-04-21): primary-trial-name query expansion.
    2: 
    3: Companion to `regulatory_expander` (M-28). Where M-28 adds
    4: `{question} site:{anchor_host}` queries from a per-domain anchor list,
    5: M-35 adds `"{anchor_trial}" {question}` queries from a per-SLUG anchor
    6: list. Trial names are query-specific (tirzepatide's pivotals differ
    7: from metformin's) so they live per-sweep-slug rather than per-domain.
    8: 
    9: The Codex DR pass-11 gap #1 on V23: "Replace the citation mix with
   10: primary SURPASS-1..SURPASS-6, SURPASS-CVOT, SURMOUNT-2/4 trial papers
   11: as first-class sources." V23's corpus had 62 rows mentioning those
   12: trial names but mostly conference abstracts and post-hoc pooled
   13: analyses — the NEJM/Lancet primaries for SURPASS-1/2/3 and SURMOUNT-1
   14: were missing. Targeted `"SURPASS-1" {question}` queries surface the
   15: primary trial publication directly.
   16: 
   17: Design invariants (same discipline as M-28):
   18:   - Zero trial names, zero drug names, zero domain terms in this
   19:     module. All such content lives in YAML templates.
   20:   - Template-driven: the caller chooses the anchors per sweep slug
   21:     by writing them into the template. This module has no baked-in
   22:     knowledge of SURPASS, SURMOUNT, or any other trial name.
   23:   - Backwards-compatible: missing key / empty dict / slug not found
   24:     all return an empty list, so the expander is safe to call
   25:     unconditionally.
   26: 
   27: Template schema (in `config/scope_templates/{domain}.yaml`):
   28: 
   29:     per_query_primary_trial_anchors:
   30:       clinical_tirzepatide_t2dm:
   31:         - SURPASS-1
   32:         - SURPASS-2
   33:         - ...
   34: 
   35: Design:
   36:   - Caller (sweep orchestrator) loads the scope template once and
   37:     calls `expand_primary_trial_queries(question, template, slug)`.
   38:   - Extra queries merge into the amplified list and travel through
   39:     the same scope-validator de-drift + Serper/S2 fanout as every
   40:     other amplified query.
   41: """
   42: from __future__ import annotations
   43: 
   44: import logging
   45: import os
   46: from typing import Any
   47: 
   48: logger = logging.getLogger("polaris_graph.primary_trial_expander")
   49: 
   50: 
   51: # PG_SWEEP_MAX_PRIMARY_TRIAL_ANCHORS: soft upper bound on how many
   52: # anchor queries this function will emit from a single slug. Defaults
   53: # to 15 (larger than M-28's 10 because drug-pivotal programs can have
   54: # 6-8 trials). Set to 0 to disable the cap.
   55: _DEFAULT_MAX_ANCHORS = 15
   56: 
   57: 
   58: def _max_anchors() -> int:
   59:     """Read the max-anchor cap from env each call (so a test can
   60:     monkey-patch without importing a module-level constant)."""
   61:     raw = os.getenv("PG_SWEEP_MAX_PRIMARY_TRIAL_ANCHORS")
   62:     if raw is None:
   63:         return _DEFAULT_MAX_ANCHORS
   64:     try:
   65:         val = int(raw)
   66:     except (TypeError, ValueError):
   67:         return _DEFAULT_MAX_ANCHORS
   68:     return max(0, val)
   69: 
   70: 
   71: def _extract_anchors(
   72:     template: dict[str, Any] | None,
   73:     slug: str,
   74: ) -> list[str]:
   75:     """Pull the trial-name anchors for a given sweep `slug` out of a
   76:     loaded scope template.
   77: 
   78:     Returns an empty list for:
   79:       - missing template
   80:       - missing `per_query_primary_trial_anchors` key
   81:       - malformed (non-dict) value
   82:       - slug not present in the dict
   83:       - empty list for the slug
   84:       - non-list value for the slug
   85: 
   86:     Trims whitespace, skips non-string entries and empties. Rejects
   87:     entries containing whitespace (a trial name with spaces would
   88:     produce a malformed quoted query).
   89:     """
   90:     if not isinstance(template, dict):
   91:         return []
   92:     if not isinstance(slug, str) or not slug.strip():
   93:         return []
   94:     by_slug = template.get("per_query_primary_trial_anchors")
   95:     if not isinstance(by_slug, dict):
   96:         return []
   97:     raw = by_slug.get(slug)
   98:     if not isinstance(raw, list):
   99:         return []
  100:     anchors: list[str] = []
  101:     for entry in raw:
  102:         if not isinstance(entry, str):
  103:             continue
  104:         stripped = entry.strip()
  105:         # Reject entries containing ANY whitespace (not just literal
  106:         # space — tabs / newlines / vertical-tab / form-feed /
  107:         # carriage-return would all break the outer `"{anchor}"`
  108:         # quoting downstream) or a double quote (ASCII U+0022 would
  109:         # break the outer quoting directly) or a backslash (could
  110:         # survive as `"BAD\" q` and escape-eat the closing quote in
  111:         # some downstream search-query parsers). M-35 pass-2 (Codex
  112:         # blocker): `str.strip()` removes leading/trailing whitespace
  113:         # but NOT interior whitespace, so `"BAD\tENTRY"` would pass
  114:         # the pre-pass-2 `" " in stripped` check. isspace() closes
  115:         # that.
  116:         if (
  117:             not stripped
  118:             or any(ch.isspace() for ch in stripped)
  119:             or '"' in stripped
  120:             or "\\" in stripped
  121:         ):
  122:             continue
  123:         anchors.append(stripped)
  124:     # Deduplicate while preserving declared order.
  125:     seen: set[str] = set()
  126:     unique: list[str] = []
  127:     for a in anchors:
  128:         if a not in seen:
  129:             seen.add(a)
  130:             unique.append(a)
  131:     return unique
  132: 
  133: 
  134: def _is_valid_doi(d: str) -> bool:
  135:     """A DOI looks like 10.<registrant>/<suffix> with no whitespace/quote/
  136:     backslash (which would break the doi.org URL or downstream quoting)."""
  137:     return (
  138:         d.startswith("10.")
  139:         and "/" in d
  140:         and not any(ch.isspace() for ch in d)
  141:         and '"' not in d
  142:         and "\\" not in d
  143:     )
  144: 
  145: 
  146: def expand_primary_trial_dois(
  147:     template: dict[str, Any] | None,
  148:     slug: str,
  149: ) -> list[str]:
  150:     """I-bug-776 (#817) layer-4 (Codex decision b): return direct doi.org
  151:     candidate URLs for the anchored primary trials of `slug`, read from
  152:     `per_query_primary_trial_dois` (a {ANCHOR: DOI} dict) in the scope template.
  153: 
  154:     These are injected as DIRECT retrieval candidates so the pivotal OA primaries
  155:     reliably enter the corpus even when guideline-dominated search ranking buries
  156:     them. They pass the SAME fetch / OA / extraction / tier / adequacy gates as
  157:     every other source (no laundering).
  158: 
  159:     Backwards-compatible: missing template / key / slug / malformed -> []. Only
  160:     well-formed DOIs are accepted; slug-scoped (no global fallback).
  161:     """
  162:     if not isinstance(template, dict):
  163:         return []
  164:     if not isinstance(slug, str) or not slug.strip():
  165:         return []
  166:     by_slug = template.get("per_query_primary_trial_dois")
  167:     if not isinstance(by_slug, dict):
  168:         return []
  169:     raw = by_slug.get(slug)
  170:     if not isinstance(raw, dict):
  171:         return []
  172:     urls: list[str] = []
  173:     seen: set[str] = set()
  174:     for _anchor, doi in raw.items():
  175:         if not isinstance(doi, str):
  176:             continue
  177:         d = doi.strip()
  178:         if not _is_valid_doi(d):
  179:             continue
  180:         url = f"https://doi.org/{d}"
  181:         if url not in seen:
  182:             seen.add(url)
  183:             urls.append(url)
  184:     return urls
  185: 
  186: 
  187: def get_primary_trial_anchors_for_slug(
  188:     template: dict[str, Any] | None,
  189:     slug: str,
  190: ) -> list[str]:
  191:     """M-42e (2026-04-22): public accessor for the raw anchor list
  192:     for a given sweep slug. Used by the evidence selector to apply
  193:     a T1 primary-paper floor. Same validation rules as `_extract_anchors`
  194:     — returns cleaned, deduplicated anchors or empty list."""
  195:     return _extract_anchors(template, slug)
  196: 
  197: 
  198: def _extract_variants(
  199:     template: dict[str, Any] | None,
  200:     slug: str,
  201: ) -> dict[str, str]:
  202:     """M-48 (2026-04-22): pull per-anchor first-author + journal variant
  203:     strings for a given sweep slug.
  204: 
  205:     Schema:
  206:         per_query_primary_trial_variants:
  207:           <slug>:
  208:             <anchor>: <free-text variant>
  209: 
  210:     Returns an empty dict for:
  211:       - missing template
  212:       - missing `per_query_primary_trial_variants` key
  213:       - malformed (non-dict) value at any level
  214:       - slug not present
  215:       - variant value not a string
  216:       - variant string contains ANY whitespace-only content or is empty
  217: 
  218:     The variant string is used as-is (wrapped in the outer query with
  219:     the base question appended). Example:
  220:         anchor = "SURPASS-2"
  221:         variant = "Frías NEJM tirzepatide semaglutide"
  222:         emitted query = `"SURPASS-2" Frías NEJM tirzepatide semaglutide {question}`
  223:     """
  224:     if not isinstance(template, dict):
  225:         return {}
  226:     if not isinstance(slug, str) or not slug.strip():
  227:         return {}
  228:     by_slug = template.get("per_query_primary_trial_variants")
  229:     if not isinstance(by_slug, dict):
  230:         return {}
  231:     raw = by_slug.get(slug)
  232:     if not isinstance(raw, dict):
  233:         return {}
  234:     out: dict[str, str] = {}
  235:     for anchor, variant in raw.items():
  236:         if not isinstance(anchor, str) or not isinstance(variant, str):
  237:             continue
  238:         a = anchor.strip()
  239:         v = variant.strip()
  240:         # Reject anchor with interior whitespace / double quote /
  241:         # backslash (same invariant as _extract_anchors) and reject
  242:         # variant containing a double quote that would break the
  243:         # outer `"{anchor}"` quoting.
  244:         if (
  245:             not a or any(ch.isspace() for ch in a)
  246:             or '"' in a or "\\" in a
  247:         ):
  248:             continue
  249:         if not v or '"' in v:
  250:             continue
  251:         out[a] = v
  252:     return out
  253: 
  254: 
  255: def get_trial_population_scope_for_slug(
  256:     template: dict[str, Any] | None,
  257:     slug: str,
  258: ) -> dict[str, str]:
  259:     """M-48 (2026-04-22): public accessor for the per-anchor population-
  260:     scope labels.
  261: 
  262:     Schema:
  263:         per_query_trial_population_scope:
  264:           <slug>:
  265:             <anchor>: "direct" | "indirect_for_t2d" | "indirect"
  266: 
  267:     Used by `label_rows_with_population_scope` to tag evidence rows
  268:     after retrieval. Missing entry → row stays unlabeled
  269:     (generator treats as "direct" by default).
  270:     """
  271:     if not isinstance(template, dict):
  272:         return {}
  273:     if not isinstance(slug, str) or not slug.strip():
  274:         return {}
  275:     by_slug = template.get("per_query_trial_population_scope")
  276:     if not isinstance(by_slug, dict):
  277:         return {}
  278:     raw = by_slug.get(slug)
  279:     if not isinstance(raw, dict):
  280:         return {}
  281:     valid_labels = {"direct", "indirect_for_t2d", "indirect"}
  282:     out: dict[str, str] = {}
  283:     for anchor, label in raw.items():
  284:         if not isinstance(anchor, str) or not isinstance(label, str):
  285:             continue
  286:         a = anchor.strip()
  287:         l_ = label.strip().lower()
  288:         if not a or any(ch.isspace() for ch in a):
  289:             continue
  290:         if l_ not in valid_labels:
  291:             continue
  292:         out[a] = l_
  293:     return out
  294: 
  295: 
  296: def label_rows_with_population_scope(
  297:     rows: list[dict[str, Any]],
  298:     template: dict[str, Any] | None,
  299:     slug: str,
  300: ) -> list[dict[str, Any]]:
  301:     """M-48 (2026-04-22): annotate evidence rows with population-scope
  302:     metadata derived from per-anchor labels.
  303: 
  304:     For each row, scan title for any configured anchor token (case-
  305:     insensitive substring match). If match found, add keys:
  306:       - `population_scope`: one of "direct" / "indirect_for_t2d" /
  307:         "indirect"
  308:       - `indirect_for_t2d`: bool (True iff label == indirect_for_t2d)
  309: 
  310:     Rows with no anchor match are unchanged. This function mutates
  311:     rows in place AND returns the list (convenience).
  312: 
  313:     Example usage in the sweep orchestrator, after `retrieval.evidence_rows`
  314:     is populated:
  315: 
  316:         rows = label_rows_with_population_scope(
  317:             retrieval.evidence_rows, template, slug
  318:         )
  319:     """
  320:     labels = get_trial_population_scope_for_slug(template, slug)
  321:     if not labels or not rows:
  322:         return rows
  323:     # Build case-insensitive lookup: {anchor_lower: (anchor_original, label)}
  324:     lookup = {a.lower(): (a, l_) for a, l_ in labels.items()}
  325:     for row in rows:
  326:         if not isinstance(row, dict):
  327:             continue
  328:         # M-48 pass-2 (Codex blocker): live retriever rows populate
  329:         # `statement` with the candidate title (not `title`). Read
  330:         # from title / statement / source_title in that order so the
  331:         # labeler works on both live rows and fixture rows.
  332:         title = ""
  333:         for key in ("title", "statement", "source_title"):
  334:             v = row.get(key)
  335:             if isinstance(v, str) and v:
  336:                 title = v
  337:                 break
  338:         title_l = title.lower()
  339:         for anchor_l, (_anchor, label) in lookup.items():
  340:             if anchor_l in title_l:
  341:                 row["population_scope"] = label
  342:                 row["indirect_for_t2d"] = (label == "indirect_for_t2d")
  343:                 row["_m48_anchor_match"] = _anchor
  344:                 break
  345:     return rows
  346: 
  347: 
  348: def expand_primary_trial_queries(
  349:     question: str,
  350:     template: dict[str, Any] | None,
  351:     slug: str,
  352: ) -> list[str]:
  353:     """Return anchor + variant queries for a given sweep slug.
  354: 
  355:     For each configured anchor:
  356:       - emits `"{anchor}" {question}` (original M-35 form)
  357:       - IF the anchor has a variant in `per_query_primary_trial_variants`,
  358:         also emits `"{anchor}" {variant} {question}` (M-48 form)
  359: 
  360:     The variant query carries first-author surname + target journal to
  361:     raise primary-publication landing probability. V27 hit 4/11 primary
  362:     trials with anchor-only queries; M-48 aims for ≥9/11.
  363: 
  364:     Args:
  365:         question: the user's research question (or any base query text).
  366:         template: the loaded scope template dict (or None if none set).
  367:         slug: the sweep slug used to key into
  368:             `per_query_primary_trial_anchors` and
  369:             `per_query_primary_trial_variants`.
  370: 
  371:     Returns:
  372:         A list of query strings; order is `[anchor1, anchor1_variant,
  373:         anchor2, anchor2_variant, ...]` for anchors with variants, else
  374:         `[anchor1, anchor2, ...]`. Total capped by
  375:         `PG_SWEEP_MAX_PRIMARY_TRIAL_ANCHORS` applied to the ANCHOR count
  376:         (variants do not count against the cap so that capped runs
  377:         retain their variant queries).
  378: 
  379:     Pure and deterministic — no network, no state.
  380:     """
  381:     base = (question or "").strip()
  382:     if not base:
  383:         return []
  384:     anchors = _extract_anchors(template, slug)
  385:     if not anchors:
  386:         return []
  387:     cap = _max_anchors()
  388:     if cap > 0 and len(anchors) > cap:
  389:         logger.info(
  390:             "[primary_trial_expander] slug=%r has %d anchors; capped "
  391:             "to %d via PG_SWEEP_MAX_PRIMARY_TRIAL_ANCHORS",
  392:             slug, len(anchors), cap,
  393:         )
  394:         anchors = anchors[:cap]
  395:     variants = _extract_variants(template, slug)
  396:     queries: list[str] = []
  397:     variant_count = 0
  398:     for anchor in anchors:
  399:         queries.append(f'"{anchor}" {base}')
  400:         variant = variants.get(anchor)
  401:         if variant:
  402:             queries.append(f'"{anchor}" {variant} {base}')
  403:             variant_count += 1
  404:     logger.info(
  405:         "[primary_trial_expander] emitted %d queries (%d anchors + "
  406:         "%d variants) for slug=%r base=%r",
  407:         len(queries), len(anchors), variant_count, slug, base[:60],
  408:     )
  409:     return queries

