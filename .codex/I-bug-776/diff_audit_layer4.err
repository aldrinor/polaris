  891: def _fetch_content(url: str, max_chars: int) -> tuple[str, bool, str, str]:
  892:     """Fetch URL content using the AccessBypass cascade (Crawl4AI +
  893:     Jina Reader + Firecrawl concurrent, fallback to direct HTTP +
  894:     Archive.org + institutional proxy + Sci-Hub).
  895: 
  896:     BUG-FETCH-R8d (2026-04-18): the live smoke test of
  897:     clinical_tirzepatide_t2dm showed 19/20 candidates failed via the
  898:     previous naive httpx.Client. `src/tools/access_bypass.py` already
  899:     had the full cascade (including BUG-BROTLI fix, concurrent Crawl4AI
  900:     /Jina/Firecrawl, paywall detection) but pipeline A wasn't wired
  901:     to it. This is the wiring.
  902: 
  903:     The AccessBypass call is async; live_retriever's fetch loop is
  904:     sync by historical choice. We run the async call in a fresh event
  905:     loop per URL. Full async refactor of run_live_retrieval (with
  906:     asyncio.gather for concurrency) is tracked as R-RETRIEVE-ASYNC in
  907:     docs/todo_list.md.
  908: 
  909:     Env opt-out: set PG_DISABLE_ACCESS_BYPASS=1 to fall back to the
  910:     naive httpx path (useful when Playwright/Crawl4AI is unavailable).
  911:     """
  912:     if os.getenv("PG_DISABLE_ACCESS_BYPASS", "0") == "1":
  913:         # M-45 pass-2: record env-opt-out so diagnostics can see it.
  914:         _m45_record_fetch_telemetry(
  915:             url, "httpx_naive", "pg_disable_access_bypass=1"
  916:         )
  917:         return _fetch_content_httpx_naive(url, max_chars)
  918:     try:
  919:         from src.tools.access_bypass import AccessBypass
  920:     except Exception as exc:
  921:         logger.warning(
  922:             "[live_retriever] AccessBypass unavailable (%s); "
  923:             "falling back to naive httpx", exc,
  924:         )
  925:         _m45_record_fetch_telemetry(
  926:             url, "httpx_naive", f"access_bypass_import_failed: {exc}"
  927:         )
  928:         return _fetch_content_httpx_naive(url, max_chars)
  929: 
  930:     # Run AccessBypass in a dedicated thread so each call gets its own
  931:     # fresh event loop. This works whether we're called from sync or
  932:     # async context (expansion path runs inside a live loop). Crawl4AI
  933:     # leaves background tasks that make subsequent asyncio.run() in the
  934:     # same thread fail with "cannot be called from a running event loop".
  935:     result_holder: dict[str, Any] = {}
  936: 
  937:     def _bypass_worker() -> None:
  938:         try:
  939:             bypass = AccessBypass()
  940:             result_holder["value"] = asyncio.run(
  941:                 bypass.fetch_with_bypass(url, prefer_legal=True)
  942:             )
  943:         except Exception as exc:  # noqa: BLE001
  944:             result_holder["error"] = exc
  945: 
  946:     worker = threading.Thread(target=_bypass_worker, daemon=True)
  947:     worker.start()
  948:     # BUG-FETCH-R8d medium-1 (Codex pass 4): bound the join so a wedged
  949:     # Crawl4AI/Playwright browser startup/cleanup can't hang the sweep
  950:     # indefinitely. AccessBypass has internal timeouts but they don't
  951:     # cover every subprocess/import/browser-cleanup failure mode.
  952:     # Default 90s = Crawl4AI worst-case (~70s) + margin. Override via
  953:     # PG_FETCH_DEADLINE_SECONDS. Set to 0 to disable (not recommended).
  954:     try:
  955:         deadline = float(os.getenv("PG_FETCH_DEADLINE_SECONDS", "90"))
  956:     except ValueError:
  957:         deadline = 90.0
  958:     worker.join(timeout=deadline if deadline > 0 else None)
  959:     if worker.is_alive():
  960:         logger.warning(
  961:             "[live_retriever] AccessBypass timed out after %.0fs for %s "
  962:             "— falling back to naive httpx (thread will continue as daemon)",
  963:             deadline, url[:80],
  964:         )
  965:         # M-45 pass-2: record AccessBypass timeout so diagnostics can
  966:         # distinguish timeout from backend refusal.
  967:         _m45_record_fetch_telemetry(
  968:             url, "httpx_naive", f"access_bypass_timeout_{int(deadline)}s",
  969:         )
  970:         return _fetch_content_httpx_naive(url, max_chars)
  971: 
  972:     if "error" in result_holder:
  973:         exc = result_holder["error"]
  974:         logger.warning(
  975:             "[live_retriever] AccessBypass raised for %s: %s: %s",
  976:             url[:80], type(exc).__name__, exc,
  977:         )
  978:         _m45_record_fetch_telemetry(
  979:             url, "httpx_naive",
  980:             f"access_bypass_raised_{type(exc).__name__}",
  981:         )
  982:         return _fetch_content_httpx_naive(url, max_chars)
  983:     if "value" not in result_holder:
  984:         logger.warning(
  985:             "[live_retriever] AccessBypass produced no result for %s",
  986:             url[:80],
  987:         )
  988:         _m45_record_fetch_telemetry(
  989:             url, "httpx_naive", "access_bypass_no_result"
  990:         )
  991:         return _fetch_content_httpx_naive(url, max_chars)
  992:     result = result_holder["value"]
  993: 
  994:     method = getattr(result, "access_method", "unknown") or "unknown"
  995:     if not result.success or not result.content:
  996:         reason = (result.metadata or {}).get("reason") if hasattr(result, "metadata") else None
  997:         logger.info(
  998:             "[live_retriever] fetch_miss %s (method=%s reason=%s)",
  999:             url[:80], method, reason or "no_content",
 1000:         )
 1001:         # M-45 pass-2: record the winning backend + reason even on miss
 1002:         # so downstream audits can see which backend was last invoked.
 1003:         _m45_record_fetch_telemetry(url, method, reason or "no_content")
 1004:         return "", False, "", ""
 1005:     # BUG-M-14 (Codex pass 14): extract the full page title from the
 1006:     # raw result.content BEFORE _strip_html removes <title> tags. Jina
 1007:     # markdown has "Title: X" on first line; Crawl4AI cleaned text has
 1008:     # the same. HTML fetches have <title>.
 1009:     extracted_title = _extract_title_from_content(result.content)
 1010:     # BUG-M-17 (Codex pass 2): detect article-type from body.
 1011:     body_type = _detect_article_type_from_body(result.content)
 1012:     # result.content is already extracted (Jina = markdown, Crawl4AI =
 1013:     # cleaned text). _strip_html is a safety net for direct-HTTP path
 1014:     # which returns raw HTML.
 1015:     content = _strip_html(result.content)[:max_chars]

