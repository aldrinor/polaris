 1282:     # ── Rule 8b (BUG-M-17, Codex pass 2): body-inspection override.
 1283:     # When live_retriever._detect_article_type_from_body found explicit
 1284:     # article-type metadata (meta tag / JSON-LD / Frontiers section
 1285:     # header / PRISMA marker / "we report a case" etc.) in the fetched
 1286:     # content, that secondary signal trumps the title-only heuristics.
 1287:     # Applied BEFORE R9/R10 so OpenAlex metadata can't upgrade a
 1288:     # body-detected case-report/perspective to T1.
 1289:     #
 1290:     # M-17f (Codex pass 7 structural pivot): gate the override by the
 1291:     # title-diagnostic check. If the title already carries explicit
 1292:     # article-type keywords ("systematic review", "case report",
 1293:     # "clinical practice guideline", etc.), R9/R10 already has enough
 1294:     # evidence to classify correctly, and body-signal false positives
 1295:     # must NOT demote primary papers. Body signal is logged as
 1296:     # advisory in this branch and does not change tier.
 1297:     body_signal = (signals.body_article_type or "").upper()
 1298:     if body_signal in ("SR_MA", "CASE_REPORT", "PERSPECTIVE", "GUIDELINE"):
 1299:         # M-17f: suppress override when title is article-type diagnostic
 1300:         title_has_article_type = _title_is_diagnostic_for_article_type(signals.title)
 1301:         # M-17g (Codex pass 8 CONDITIONAL): also suppress when title has
 1302:         # strong primary-study evidence AND OpenAlex confirms peer-
 1303:         # reviewed journal article. This prevents body-signal false
 1304:         # positives from demoting RCT titles such as "Randomized
 1305:         # placebo-controlled trial" or named-trial titles like
 1306:         # "SURPASS-9 trial".
 1307:         pub_type_for_gate = (signals.openalex_publication_type or "").lower()
 1308:         src_type_for_gate = (signals.openalex_source_type or "").lower()
 1309:         is_peer_reviewed_for_gate = (
 1310:             signals.openalex_is_peer_reviewed is True
 1311:             or src_type_for_gate == "journal"
 1312:         )
 1313:         title_is_primary_study = (
 1314:             _detect_primary_study_signal(signals.title)
 1315:             and is_peer_reviewed_for_gate
 1316:             and pub_type_for_gate in ("article", "review")
 1317:         )
 1318:         if title_has_article_type or title_is_primary_study:
 1319:             # Title already carries diagnostic evidence (article-type
 1320:             # keyword OR strong primary-study signal on a peer-reviewed
 1321:             # journal article). Log body as advisory and FALL THROUGH
 1322:             # to R9/R10 (do not return).
 1323:             gate_reason = (
 1324:                 "article-type" if title_has_article_type else "primary-study"
 1325:             )
 1326:             result.reasons.append(
 1327:                 f"R8b_body_signal_advisory_only: body={body_signal} "
 1328:                 f"(title is diagnostic [{gate_reason}]; trusting R9/R10)"
 1329:             )
 1330:         else:
 1331:             # Title is NOT diagnostic — body signal is the primary
 1332:             # article-type evidence and wins over R9/R10.
