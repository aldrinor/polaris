  192: def load_scope_template(domain: str) -> dict[str, Any]:
  193:     """Load `config/scope_templates/{domain}.yaml` as a dict.
  194: 
  195:     Raises RuntimeError if the file doesn't exist or yaml isn't installed.
  196:     """
  197:     if yaml is None:
  198:         raise RuntimeError(
  199:             "PyYAML is required for scope_gate. Install via "
  200:             "`pip install pyyaml`."
  201:         )
  202:     if domain not in SUPPORTED_DOMAINS:
  203:         raise ValueError(
  204:             f"domain={domain!r} not in SUPPORTED_DOMAINS. "
  205:             f"Options: {sorted(SUPPORTED_DOMAINS)}"
  206:         )
  207:     path = _SCOPE_TEMPLATES_DIR / f"{domain}.yaml"
  208:     if not path.exists():
  209:         raise RuntimeError(
  210:             f"Scope template {path} does not exist. Phase 2c is responsible "
  211:             f"for creating this file; run the rebuild Phase 2c step first."
  212:         )
  213:     with path.open("r", encoding="utf-8") as f:
  214:         data = yaml.safe_load(f) or {}
  215:     if not isinstance(data, dict):
  216:         raise RuntimeError(
  217:             f"Scope template {path} did not parse to a dict (got "
  218:             f"{type(data).__name__}). Check the YAML syntax."
  219:         )
  220:     return data
  221: 
