 1337:                 result.reasons.append(
 1338:                     "Body-inspection detected systematic review / meta-"
 1339:                     "analysis signal (meta tag, JSON-LD, PRISMA "
 1340:                     "reference, or abstract lead). T2 regardless of "
 1341:                     "title."
 1342:                 )
 1343:             elif body_signal == "CASE_REPORT":
 1344:                 result.tier = TierLevel.T4
 1345:                 result.confidence = 0.8
 1346:                 result.matched_rules.append("R8b_body_case_report")
 1347:                 result.reasons.append(
 1348:                     "Body-inspection detected case-report signal. T4 "
 1349:                     "regardless of title."
 1350:                 )
 1351:             elif body_signal == "GUIDELINE":
 1352:                 result.tier = TierLevel.T4
 1353:                 result.confidence = 0.8
 1354:                 result.matched_rules.append("R8b_body_guideline")
 1355:                 result.reasons.append(
 1356:                     "Body-inspection detected guideline / consensus / "
 1357:                     "practice-guide signal. T4 regardless of title."
 1358:                 )
 1359:             else:  # PERSPECTIVE
