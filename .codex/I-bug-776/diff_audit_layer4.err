  147: 
  148: def filter_search_results(
  149:     candidates: list[SearchCandidate],
  150:     research_question: str,
  151:     threshold: Optional[float] = None,
  152: ) -> FilterResult:
  153:     """Filter search candidates by semantic similarity to the research question.
  154: 
  155:     Args:
  156:         candidates: List of SearchCandidate. Must have .snippet_text.
  157:         research_question: The canonical question from protocol.json.
  158:             This is the ONLY anchor — do not use state.query or
  159:             amplifier-derived variants here.
  160:         threshold: Override for PG_OFFTOPIC_PREFETCH_THRESHOLD. None
  161:             uses the env var (default 0.25).
  162: 
  163:     Returns:
  164:         FilterResult with kept / rejected lists and telemetry counts.
  165:         FAIL-OPEN: if the embedder fails to load or similarity raises,
  166:         we keep everything and log a warning. Retrieval continues with
  167:         the looser post-fetch filter as the second line of defense.
  168:     """
  169:     if not candidates:
  170:         return FilterResult(
  171:             kept=[], rejected=[], threshold_used=0.0,
  172:             total_in=0, total_kept=0, total_rejected=0,
  173:         )
  174: 
  175:     if threshold is None:
  176:         threshold = float(
  177:             os.getenv("PG_OFFTOPIC_PREFETCH_THRESHOLD", "0.25")
  178:         )
  179: 
  180:     # Anchor must be non-empty
  181:     anchor = (research_question or "").strip()
  182:     if not anchor:
  183:         logger.warning(
  184:             "[prefetch_offtopic] empty research_question — FAIL-OPEN, "
  185:             "passing all %d candidates",
  186:             len(candidates),
  187:         )
  188:         return FilterResult(
  189:             kept=list(candidates), rejected=[], threshold_used=threshold,
  190:             total_in=len(candidates), total_kept=len(candidates),
  191:             total_rejected=0,
  192:         )
  193: 
  194:     embedder = _load_embedder()
  195:     if embedder is None:
  196:         return FilterResult(
  197:             kept=list(candidates), rejected=[], threshold_used=threshold,
  198:             total_in=len(candidates), total_kept=len(candidates),
  199:             total_rejected=0,
  200:         )
  201: 
  202:     snippets = [c.snippet_text or "" for c in candidates]
  203:     sims = _similarity_scores(embedder, anchor, snippets)
  204: 
  205:     kept: list[SearchCandidate] = []
  206:     rejected: list[tuple[SearchCandidate, float, str]] = []
  207:     for cand, sim in zip(candidates, sims):
  208:         if not cand.snippet_text.strip():
  209:             # Keep candidates with no snippet — we need to fetch to know.
  210:             kept.append(cand)
  211:             continue
  212:         if sim >= threshold:
  213:             kept.append(cand)
  214:         else:
  215:             rejected.append((cand, float(sim), "below_prefetch_threshold"))
  216: 
  217:     logger.info(
  218:         "[prefetch_offtopic] filter threshold=%.2f kept=%d rejected=%d "
  219:         "total=%d",
  220:         threshold, len(kept), len(rejected), len(candidates),
  221:     )
  222: 
  223:     return FilterResult(
  224:         kept=kept, rejected=rejected, threshold_used=threshold,
  225:         total_in=len(candidates),
  226:         total_kept=len(kept),
  227:         total_rejected=len(rejected),
  228:     )

