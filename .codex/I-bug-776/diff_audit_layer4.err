 1256:             f"without full-text retrieval. T7."
 1257:         )
 1258:         return result
 1259: 
 1260:     # ── Rule 7: Preprint servers (T4 — not peer-reviewed yet)
 1261:     if _domain_matches(domain, PREPRINT_DOMAINS):
