  864:         if diagnostics["failure_mode"] != "timeout":
  865:             diagnostics["failure_mode"] = "thin_content"
  866:         return "", diagnostics
  867:     # Paywall-shell detection: body_type marker set by
  868:     # _detect_article_type_from_body. We still build a provenance
  869:     # quote from the content but tag the diagnostic so downstream
  870:     # audits can filter these out if they want only full-text sources.
  871:     if body_type == "paywall_shell":
  872:         diagnostics["failure_mode"] = "paywall_shell"
  873:         # Continue to build the quote — the shell may still contain
  874:         # enough abstract text to hit ≥100 chars. Eligibility is
  875:         # determined by the provenance-quote length check below.
  876:     quote = _build_provenance_quote(
  877:         content, head_chars=min(1500, max_chars), window_chars=500,
  878:         max_total_chars=max_chars,
  879:     )
  880:     if not quote or len(quote) < 100:
  881:         if not diagnostics["failure_mode"]:
  882:             diagnostics["failure_mode"] = "thin_content"
  883:         return "", diagnostics
  884:     diagnostics["eligible"] = True
  885:     if diagnostics["failure_mode"] == "paywall_shell":
  886:         # Eligible despite shell marker — abstract-only case.
  887:         diagnostics["failure_mode"] = ""
  888:     return quote, diagnostics
