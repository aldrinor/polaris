  497: def _extract_doi_from_url(url: str) -> str:
  498:     """Extract a DOI from a URL if present. Handles Frontiers
  499:     (`/10.3389/fphar.2022.1016639/full`), JAMA, NEJM, OUP, Sage,
  500:     ACS, RSC, Wiley, and direct `doi.org/...` URLs. MDPI URLs don't
  501:     embed DOIs; return empty there.
  502:     """
  503:     if not url:
  504:         return ""
  505:     # Direct DOI URL
  506:     u = url.strip()
  507:     if "doi.org/" in u.lower():
  508:         idx = u.lower().find("doi.org/") + len("doi.org/")
  509:         doi = u[idx:].split("?")[0].split("#")[0].rstrip("/")
  510:         return doi
  511:     # Embedded DOI in publisher URLs
  512:     m = _DOI_FROM_URL_RE.search(u)
  513:     if m:
  514:         return m.group(1).rstrip("/").rstrip(".")
  515:     return ""
  516: 
  517: 
  518: def _openalex_enrich(url: str, title: str) -> dict[str, Any]:
  519:     """Query OpenAlex for pub_type / source_type / is_peer_reviewed.
  520: 
  521:     M-13 (BUG-M-13, Codex pass 13): prefer DOI-based lookup over
  522:     title search. When the URL embeds a DOI (Frontiers, JAMA, NEJM,
  523:     OUP, etc.), OpenAlex's /works/doi:<doi> endpoint is exact and
  524:     always returns the full display_name. Title-based search often
  525:     fails when Serper truncated the title or returned a variant
  526:     that OpenAlex doesn't index. Falls back to title search when no
  527:     DOI can be extracted (e.g., MDPI URLs, publisher blog posts).
  528:     """
  529:     try:
  530:         doi = _extract_doi_from_url(url)
  531:         with httpx.Client(timeout=DEFAULT_HTTP_TIMEOUT) as c:
  532:             if doi:
  533:                 # Exact DOI lookup — most reliable. OpenAlex accepts
  534:                 # both the bare DOI and the URL form; use bare DOI.
  535:                 r = c.get(f"{OPENALEX_ENDPOINT}/doi:{doi}")
  536:                 if r.status_code != 200:
  537:                     # Fall back to title search if DOI not indexed
  538:                     r = c.get(
  539:                         OPENALEX_ENDPOINT,
  540:                         params={
  541:                             "search": (title or url)[:200],
  542:                             "per-page": 1,
  543:                         },
  544:                     )
  545:                     if r.status_code != 200:
  546:                         return {}
  547:                     data = r.json()
  548:                     results = data.get("results", [])
  549:                     if not results:
  550:                         return {}
  551:                     work = results[0]
  552:                 else:
  553:                     work = r.json()  # single-work response from /works/doi
  554:             else:
  555:                 r = c.get(
  556:                     OPENALEX_ENDPOINT,
  557:                     params={
  558:                         "search": (title or url)[:200],
  559:                         "per-page": 1,
  560:                     },
  561:                 )
  562:                 if r.status_code != 200:
  563:                     return {}
  564:                 data = r.json()
  565:                 results = data.get("results", [])
  566:                 if not results:
  567:                     return {}
  568:                 work = results[0]
  569:         primary = work.get("primary_location") or {}
  570:         source = primary.get("source") or {}
  571:         return {
  572:             "openalex_pub_type": work.get("type", "") or "",
  573:             "openalex_source_type": source.get("type", "") or "",
  574:             "is_peer_reviewed": bool(
  575:                 work.get("type") in ("article", "review")
  576:                 and source.get("type") == "journal"
  577:             ),
  578:             "openalex_id": work.get("id", ""),
  579:             # BUG-M-12 (Codex pass 12): preserve OpenAlex's full
  580:             # display_name. Serper snippet titles are often truncated

