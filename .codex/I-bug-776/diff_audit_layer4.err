  921: def classify_source_tier(
  922:     signals: ClassificationSignals,
  923: ) -> ClassificationResult:
  924:     """Classify a source into T1-T7 (or UNKNOWN) using rules.
  925: 
  926:     Rules fire in priority order. The first match wins; later rules
  927:     cannot overturn an earlier decision (so rule ordering is
  928:     load-bearing). Every match appends to result.reasons so the user
  929:     can audit why a tier was assigned.
  930: 
  931:     Returns TierLevel.UNKNOWN rather than silent BRONZE when no rule
  932:     matches — see module docstring for rationale.
  933:     """
  934:     result = ClassificationResult(
  935:         tier=TierLevel.UNKNOWN,
  936:         confidence=0.0,
  937:     )
  938:     domain = _normalize_domain(signals.url)
  939:     result.signals_used = {
  940:         "domain": domain,
  941:         "source_type_hint": signals.source_type_hint,
  942:         "publication_type": signals.openalex_publication_type,
  943:         "content_length": signals.fetched_content_length,
  944:     }
  945: 
  946:     # ── Rule 0 (BLOCKED): Retracted papers are never classified positively
  947:     if signals.openalex_is_retracted:
  948:         result.tier = TierLevel.UNKNOWN  # caller should exclude; not T1-T7
  949:         result.confidence = 1.0
  950:         result.matched_rules.append("R0_retracted")
  951:         result.reasons.append(
  952:             "Paper flagged retracted by OpenAlex; excluded from tier scoring. "
  953:             "Caller should filter retracted sources before composition."
  954:         )
  955:         return result
  956: 
  957:     # ── Rule Pre-1 (T6, M-18b from DR audit pass 1): Social platform
  958:     # / general-interest portal exclusion. Must fire BEFORE R1 stub-
  959:     # content so that Facebook/Twitter/Reddit pages are classified by
  960:     # domain authority, not by how much text happened to be fetched.
  961:     # A Facebook "Black Box Warning" post is not more citable just
  962:     # because its body happens to be > 1000 chars.
  963:     if _domain_matches(domain, SOCIAL_PLATFORM_DOMAINS):
  964:         result.tier = TierLevel.T6
  965:         result.confidence = 0.98
  966:         result.matched_rules.append("RP1_social_platform_early")
  967:         result.reasons.append(
  968:             f"Domain {domain!r} is a social platform / general-interest "
  969:             f"portal. User-generated or aggregator content; never T1 "
  970:             f"primary research regardless of content length or OpenAlex "
  971:             f"metadata. M-18b: fires BEFORE R1 stub so tier cannot be "
  972:             f"laundered via large body text."
  973:         )
  974:         return result
  975: 
  976:     # ── Rule 1 (T7 stub): Tiny content = stub regardless of venue
  977:     # This runs early because even a JAMA paper fetched as 500-char
  978:     # abstract is effectively a stub for evaluator purposes.
  979:     if signals.fetched_content_length and signals.fetched_content_length < T7_STUB_CONTENT_CHARS:
  980:         result.tier = TierLevel.T7
  981:         result.confidence = 1.0
  982:         result.matched_rules.append("R1_stub_content_length")
  983:         result.reasons.append(
  984:             f"Fetched body is {signals.fetched_content_length} chars "
  985:             f"(< {T7_STUB_CONTENT_CHARS} threshold) — classified T7 stub "
  986:             f"regardless of venue. Full-text retrieval would be needed "
  987:             f"to upgrade."
  988:         )
  989:         return result
  990: 
  991:     # ── Rule 2a (T6): Low-provenance document hosts. A government PDF
  992:     # re-hosted on Scribd has unknown authenticity; do NOT elevate to T3
  993:     # just because source_type_hint says "government_report". This fires
  994:     # before the regulatory rule specifically to catch laundering.
  995:     if _domain_matches(domain, LOW_PROVENANCE_HOSTS):
  996:         result.tier = TierLevel.T6
  997:         result.confidence = 0.95
  998:         result.matched_rules.append("R2a_low_provenance_host")
  999:         result.reasons.append(
 1000:             f"Domain {domain!r} is a user-upload document host with no "
 1001:             f"provenance guarantees. T6 regardless of upstream metadata "
 1002:             f"hints; the authentic source should be located at the "
 1003:             f"original issuer's URL."
 1004:         )
 1005:         return result
