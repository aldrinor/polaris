  136: #
  137: # Covers Codex DR pass-11 gap #1: "Replace the citation mix with
  138: # primary SURPASS-1..SURPASS-6, SURPASS-CVOT, SURMOUNT-2/4 trial
  139: # papers as first-class sources." V23 corpus had 62 trial-mention
  140: # rows but mostly conference abstracts and post-hoc pooled analyses;
  141: # the primary NEJM / Lancet publications for SURPASS-1/2/3 and
  142: # SURMOUNT-1 were absent. Targeted `"SURPASS-1" {question}` queries
  143: # surface the pivotal trial publication directly.
  144: per_query_primary_trial_anchors:
  145:   clinical_tirzepatide_t2dm:
  146:     - SURPASS-1       # Rosenstock et al., Lancet 2021 — monotherapy
  147:     - SURPASS-2       # Frías et al., NEJM 2021 — vs semaglutide
  148:     - SURPASS-3       # Ludvik et al., Lancet 2021 — vs insulin degludec
  149:     - SURPASS-4       # Del Prato et al., Lancet 2021 — high-CV-risk
  150:     - SURPASS-5       # Dahl et al., JAMA 2022 — + insulin glargine
  151:     - SURPASS-6       # Rosenstock et al., JAMA 2023 — vs insulin lispro
  152:     - SURPASS-CVOT    # Ongoing cardiovascular outcome trial
  153:     - SURMOUNT-1      # Jastreboff et al., NEJM 2022 — obesity
  154:     - SURMOUNT-2      # Garvey et al., Lancet 2023 — obesity + T2D
  155:     - SURMOUNT-3      # Wadden et al., Nat Med 2023 — after ILI
  156:     - SURMOUNT-4      # Aronne et al., JAMA 2023 — weight maintenance
  157:   # I-bug-776 (#817, Codex b1): the four landmark NOAC-vs-warfarin pivotal RCTs
  158:   # that every NVAF anticoagulation guideline (ESC / ACC-AHA) is built on.
  159:   # Without these anchors a "current guidelines" question surfaces only the
  160:   # guidelines/reviews (T2) and never the underlying primaries (T1) -> T1<3 ->
  161:   # corpus_inadequate. Slug-scoped (no global fallback per Codex guardrail).
  162:   clinical_afib_anticoagulation:
  163:     - ARISTOTLE            # Granger et al., NEJM 2011 — apixaban vs warfarin
  164:     - ROCKET-AF            # Patel et al., NEJM 2011 — rivaroxaban vs warfarin
  165:     - RE-LY                # Connolly et al., NEJM 2009 — dabigatran vs warfarin
  166:     - ENGAGE-AF-TIMI-48    # Giugliano et al., NEJM 2013 — edoxaban vs warfarin
  167: 
  168: # M-48 (2026-04-22): per-anchor first-author + journal query variants.
  169: # Codex V28 plan pass-1 approved; Codex V28 plan pass-2 APPROVED.
  170: # V27 retrieved 4/11 primary trials; Codex required per-anchor variants
  171: # (first-author surname + target journal) to raise primary landing
  172: # probability from ~36% to target ≥90%. Each variant is a SECOND query
  173: # emitted alongside `"{anchor}" {question}`, so retrieval cost per
  174: # anchor roughly doubles (acceptable: 11 * $0.0001 extra ≈ $0.001).
  175: #
  176: # Variants are optional. If anchor has no variant entry, only the
  177: # original anchor query fires (backwards-compatible).
  178: per_query_primary_trial_variants:
  179:   clinical_tirzepatide_t2dm:
  180:     SURPASS-1: Rosenstock Lancet tirzepatide monotherapy
  181:     SURPASS-2: Frías NEJM tirzepatide semaglutide
  182:     SURPASS-3: Ludvik Lancet tirzepatide insulin degludec
  183:     SURPASS-4: Del Prato Lancet tirzepatide glargine cardiovascular
  184:     SURPASS-5: Dahl JAMA tirzepatide glargine add-on
  185:     SURPASS-6: Rosenstock JAMA tirzepatide lispro premeal
  186:     SURPASS-CVOT: Nicholls tirzepatide cardiovascular outcomes MACE
  187:     SURMOUNT-1: Jastreboff NEJM tirzepatide obesity weight loss
  188:     SURMOUNT-2: Garvey Lancet tirzepatide obesity type 2 diabetes
  189:     SURMOUNT-3: Wadden Nature Medicine tirzepatide intensive lifestyle
  190:     SURMOUNT-4: Aronne JAMA tirzepatide weight maintenance
  191:   # I-bug-776 (#817): first-author + journal + drug variants raise the
  192:   # primary-publication landing probability for the afib anchors.
  193:   clinical_afib_anticoagulation:
  194:     ARISTOTLE: Granger NEJM apixaban warfarin atrial fibrillation
  195:     ROCKET-AF: Patel NEJM rivaroxaban warfarin atrial fibrillation
  196:     RE-LY: Connolly NEJM dabigatran warfarin atrial fibrillation
  197:     ENGAGE-AF-TIMI-48: Giugliano NEJM edoxaban warfarin atrial fibrillation
  198: 
  199: # I-bug-776 (#817) LAYER 4 (Codex decision b): per-anchor primary-trial DOIs,
  200: # injected as DIRECT doi.org candidate URLs (not search queries). For a
  201: # guideline-synthesis question, search ranking buries the pivotal primaries, so
  202: # the layer-3 anchor SEARCH queries don't surface them. These DOIs are OA-verified
