    1: """
    2: Pre-fetch off-topic filter — HONEST-REBUILD Phase 2d.
    3: 
    4: Filters search results BEFORE full-page fetching so we don't waste
    5: network / parse budget on results whose title+snippet is already
    6: clearly unrelated to the research question.
    7: 
    8: WHY THIS EXISTS (PG_LB_SA_02_CONTENT_AUDIT Section E-03):
    9: - The pre-rebuild pipeline fetched every search result, extracted
   10:   evidence, then filtered off-topic evidence during synthesis.
   11: - The legacy PG_OFFTOPIC_THRESHOLD=0.15 was so low that near-zero-
   12:   similarity evidence (e.g., Japan health insurance general articles
   13:   when the query was semaglutide CV risk) survived.
   14: - The "risk axis retained below threshold" path further defeated
   15:   tightening attempts because its floor was pinned at 0.15.
   16: 
   17: PHASE 2D APPROACH:
   18: - Filter snippets BEFORE fetch using a looser threshold
   19:   (PG_OFFTOPIC_PREFETCH_THRESHOLD, default 0.25).
   20: - Filter evidence AFTER fetch + extraction using a tighter threshold
   21:   (PG_OFFTOPIC_THRESHOLD, default 0.35).
   22: - Both stages use the scope-protocol's research_question as the
   23:   canonical anchor, not a free-form state.query that could drift.
   24: 
   25: This module is cheap to call — it uses the embedding service we
   26: already load for evidence deduplication, so there's no new model
   27: cost.
   28: """
   29: 
   30: from __future__ import annotations
   31: 
   32: import logging
   33: import os
   34: from dataclasses import dataclass
   35: from typing import Any, Optional
   36: 
   37: logger = logging.getLogger("polaris_graph.prefetch_offtopic")
   38: 
   39: 
   40: @dataclass
   41: class SearchCandidate:
   42:     """Minimal shape of a search result for off-topic filtering.
   43: 
   44:     Callers wrap Serper / OpenAlex / Semantic Scholar results into
   45:     this shape. All fields may be empty; `snippet_text` is the only
   46:     one actually used for similarity scoring.
   47:     """
   48: 
   49:     url: str
   50:     title: str = ""
   51:     snippet: str = ""
   52:     source: str = ""            # "serper" / "openalex" / "s2" / "exa"
   53:     metadata: dict[str, Any] | None = None
   54: 
   55:     @property
   56:     def snippet_text(self) -> str:
   57:         """Text used for embedding-based similarity."""
   58:         parts = [self.title.strip(), self.snippet.strip()]
   59:         return " ".join(p for p in parts if p)
   60: 
   61: 
   62: @dataclass
   63: class FilterResult:
   64:     """Return value of filter_search_results()."""
   65: 
   66:     kept: list[SearchCandidate]
   67:     rejected: list[tuple[SearchCandidate, float, str]]  # (cand, sim, reason)
   68:     threshold_used: float
   69:     total_in: int
   70:     total_kept: int
   71:     total_rejected: int
   72: 
   73: 
   74: def _load_embedder() -> Any:
   75:     """Lazy-load the embedding service. Returns None on import failure."""
   76:     try:
   77:         from src.polaris_graph.agents.nli_verifier import (  # type: ignore
   78:             EmbeddingService,
   79:         )
   80:         return EmbeddingService()
   81:     except Exception as exc:
   82:         try:
   83:             # Fallback: sentence-transformers direct
   84:             from sentence_transformers import SentenceTransformer
   85:             model_name = os.getenv(
   86:                 "PG_EMBED_MODEL",
   87:                 "sentence-transformers/all-MiniLM-L6-v2",
   88:             )
   89:             return SentenceTransformer(model_name)
   90:         except Exception:
   91:             logger.warning(
   92:                 "[prefetch_offtopic] Embedder not available: %s — "
   93:                 "skipping filter (fail-open)",
   94:                 str(exc)[:200],
   95:             )
   96:             return None
   97: 
   98: 
   99: def _similarity_scores(
  100:     embedder: Any,
  101:     query: str,
  102:     snippets: list[str],
  103: ) -> list[float]:
  104:     """Compute cosine similarity between query and each snippet.
  105: 
  106:     Uses whichever interface the embedder exposes (`embed_batch`,
  107:     `encode`, or direct call). Returns zeros on failure.
  108:     """
  109:     if not snippets:
  110:         return []
  111:     try:
  112:         import numpy as np  # type: ignore
  113: 
  114:         if hasattr(embedder, "embed_batch"):
  115:             query_vec = embedder.embed_batch([query])[0]
  116:             snippet_vecs = embedder.embed_batch(snippets)
  117:         elif hasattr(embedder, "encode"):
  118:             query_vec = embedder.encode(query, normalize_embeddings=True)
  119:             snippet_vecs = embedder.encode(
  120:                 snippets, normalize_embeddings=True,
  121:             )
  122:         else:
  123:             return [0.0] * len(snippets)
  124: 
  125:         q = np.asarray(query_vec, dtype="float32").reshape(-1)
  126:         q_norm = np.linalg.norm(q)
  127:         if q_norm < 1e-9:
  128:             return [0.0] * len(snippets)
  129:         q = q / q_norm
  130: 
  131:         sims: list[float] = []
  132:         for vec in snippet_vecs:
  133:             s = np.asarray(vec, dtype="float32").reshape(-1)
  134:             s_norm = np.linalg.norm(s)
  135:             if s_norm < 1e-9:
  136:                 sims.append(0.0)
  137:             else:
  138:                 sims.append(float(q @ (s / s_norm)))
  139:         return sims
  140:     except Exception as exc:

