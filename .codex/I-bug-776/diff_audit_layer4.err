  905: def _detect_primary_study_signal(title: str) -> bool:
  906:     """Return True if the title contains a positive primary-research
  907:     signal (randomized trial, cohort study, named phase trial, etc.).
  908:     Used by R9 to require positive evidence before granting T1 —
  909:     merely passing OpenAlex article+journal is not enough.
  910:     """
  911:     if not title:
  912:         return False
  913:     t = title.lower()
  914:     return any(k in t for k in _PRIMARY_STUDY_TITLE_MARKERS)
