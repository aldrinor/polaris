diff --git a/Dockerfile.v6 b/Dockerfile.v6
index 5859720d..18468807 100644
--- a/Dockerfile.v6
+++ b/Dockerfile.v6
@@ -44,11 +44,14 @@ WORKDIR /app
 # neither reachable from pipeline-A or v6 backend) AND its protobuf<5
 # constraint from the v6 image only. Pipeline-B's separate `Dockerfile`
 # is untouched and retains both deps.
-COPY requirements.txt requirements-v6.txt ./
-RUN sed -e '/^google-generativeai/d' \
-        -e '/^protobuf</d' \
-        requirements.txt > /tmp/requirements-v6-pipeline-a.txt && \
-    pip install --no-cache-dir -r /tmp/requirements-v6-pipeline-a.txt -r requirements-v6.txt
+COPY requirements.txt requirements-v6.txt requirements.lock ./
+# I-cd-001 / #494: install from the deterministic uv-compiled lockfile — no
+# build-time resolver runaway. requirements.lock is compiled from the v6
+# surface: requirements.txt minus google-generativeai + protobuf< (pipeline-C
+# dead code; its protobuf<5 constraint conflicts with v6's protobuf==6.33.6)
+# plus requirements-v6.txt. requirements.txt + requirements-v6.txt stay COPY'd
+# as the lock's provenance / source of truth.
+RUN pip install --no-cache-dir -r requirements.lock
 
 # Copy application code.
 COPY src/ src/
diff --git a/docker-compose.v6.yml b/docker-compose.v6.yml
index bbc73c8d..216de18c 100644
--- a/docker-compose.v6.yml
+++ b/docker-compose.v6.yml
@@ -100,6 +100,16 @@ services:
       context: .
       dockerfile: Dockerfile.v6
     command: worker
+    # I-cd-001 / #494: the worker is a Dramatiq consumer with no HTTP server.
+    # Override the api-oriented Dockerfile.v6 HEALTHCHECK (:8000/health) with a
+    # redis-reachability check, else the worker reports "unhealthy" forever
+    # despite running fine — and api/webui that depend on it can be held back.
+    healthcheck:
+      test: ["CMD-SHELL", "python -c \"import socket; socket.create_connection(('redis', 6379), 3)\" || exit 1"]
+      interval: 30s
+      timeout: 5s
+      retries: 3
+      start_period: 15s
     env_file:
       - .env
     environment:
