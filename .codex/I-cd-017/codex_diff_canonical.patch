+
+def test_get_pin_by_date_wrong_date_returns_404(client, tmp_path: Path, db_path: Path):
+    artifact_dir = tmp_path / "wrong"
+    _write_manifest(
+        artifact_dir,
+        generator={
+            "outline_sections": ["a"],
+            "sections_kept": 1,
+            "sentences_verified": 5,
+            "sentences_dropped": 5,
+        },
+    )
+    _seed_run(
+        db_path,
+        run_id="r_w",
