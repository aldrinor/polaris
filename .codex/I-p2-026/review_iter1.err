 succeeded in 1054ms:
   1: // I-p2-026 (#765): automated WCAG 2.2 AA scan (axe-core via Playwright).
   2: //
   3: // Scans the public + canonical-bundle pages against the WCAG 2.0/2.1/2.2 A+AA
   4: // rule tags. Backend-driven pages (graph, source_review) get their API calls
   5: // intercepted with REAL fixture data (the same data the live endpoints serve)
   6: // so the FULL rendered UI is scanned — not an offline error state.
   7: //
   8: // Usage: BASE=http://127.0.0.1:PORT node tests/a11y/wcag_axe_scan.mjs
   9: // Exits non-zero if any page has serious/critical violations.
  10: import { chromium } from "playwright";
  11: import { AxeBuilder } from "@axe-core/playwright";
  12: import fs from "node:fs";
  13: import path from "node:path";
  14: import { fileURLToPath } from "node:url";
  15: 
  16: const BASE = process.env.BASE ?? "http://127.0.0.1:4019";
  17: const WCAG_TAGS = ["wcag2a", "wcag2aa", "wcag21a", "wcag21aa", "wcag22aa"];
  18: 
  19: const graphFixture = JSON.parse(
  20:   fs.readFileSync(new URL("../fixtures/graph_payload.json", import.meta.url)),
  21: );
  22: // Real source-set data the live GET /api/v6/templates serves — read straight
  23: // from the authoritative config so the source-review scan exercises the real
  24: // rendered UI (no synthetic fixture, reproducible without /tmp state).
  25: const templatesDir = fileURLToPath(
  26:   new URL("../../../config/v6_templates/", import.meta.url),
  27: );
  28: const templatesFixture = fs
  29:   .readdirSync(templatesDir)
  30:   .filter((f) => f.endsWith(".json"))
  31:   .map((f) => JSON.parse(fs.readFileSync(path.join(templatesDir, f), "utf-8")));
  32: 
  33: const PAGES = [
  34:   { name: "home", path: "/" },
  35:   { name: "sign-in", path: "/sign-in" },
  36:   { name: "inspector", path: "/inspector/v1-canonical-success" },
  37:   { name: "audit-export", path: "/runs/v1-canonical-success/audit" },
  38:   {
  39:     name: "knowledge-graph",
  40:     path: "/runs/v1-canonical-success/graph",
  41:     routes: [
  42:       {
  43:         glob: "**/api/runs/*/graph",
  44:         body: graphFixture,
  45:       },
  46:     ],
  47:   },
  48:   {
  49:     name: "source-review",
  50:     path: "/source_review?q=Is%20tirzepatide%20more%20effective%20than%20semaglutide%3F&template=clinical",
  51:     routes: [{ glob: "**/api/v6/templates", body: templatesFixture }],
  52:   },
  53: ];
  54: 
  55: const run = async () => {
  56:   const browser = await chromium.launch();
  57:   const summary = [];
  58:   for (const page of PAGES) {
  59:     const ctx = await browser.newContext({
  60:       viewport: { width: 1366, height: 900 },
  61:     });
  62:     const p = await ctx.newPage();
  63:     for (const r of page.routes ?? []) {
  64:       await p.route(r.glob, (route) =>
  65:         route.fulfill({
  66:           status: 200,
  67:           contentType: "application/json",
  68:           body: JSON.stringify(r.body),
  69:         }),
  70:       );
  71:     }
  72:     try {
  73:       await p.goto(`${BASE}${page.path}`, {
  74:         waitUntil: "networkidle",
  75:         timeout: 45000,
  76:       });
  77:       await p.waitForTimeout(1800);
  78:       const results = await new AxeBuilder({ page: p })
  79:         .withTags(WCAG_TAGS)
  80:         .analyze();
  81:       const byImpact = { critical: 0, serious: 0, moderate: 0, minor: 0 };
  82:       for (const v of results.violations) {
  83:         byImpact[v.impact ?? "minor"] =
  84:           (byImpact[v.impact ?? "minor"] ?? 0) + v.nodes.length;
  85:       }
  86:       summary.push({
  87:         page: page.name,
  88:         path: page.path,
  89:         violations: results.violations.map((v) => ({
  90:           id: v.id,
  91:           impact: v.impact,
  92:           help: v.help,
  93:           nodes: v.nodes.length,
  94:           targets: v.nodes.slice(0, 3).map((n) => n.target.join(" ")),
  95:         })),
  96:         byImpact,
  97:       });
  98:     } catch (e) {
  99:       summary.push({ page: page.name, path: page.path, error: e.message });
 100:     }
 101:     await ctx.close();
 102:   }
 103:   await browser.close();
 104:   fs.writeFileSync("/tmp/axe_summary.json", JSON.stringify(summary, null, 2));
 105: 
 106:   let blocking = 0;
 107:   for (const s of summary) {
 108:     if (s.error) {
 109:       console.log(`\n[${s.page}] ERROR: ${s.error}`);
 110:       continue;
 111:     }
 112:     const b = s.byImpact;
 113:     const bad = (b.critical ?? 0) + (b.serious ?? 0);
 114:     blocking += bad;
 115:     const flag = bad > 0 ? "✗" : "✓";
 116:     console.log(
 117:       `\n${flag} [${s.page}] crit=${b.critical} serious=${b.serious} mod=${b.moderate} minor=${b.minor}`,
 118:     );
 119:     for (const v of s.violations) {
 120:       console.log(
 121:         `    - ${v.impact?.toUpperCase()} ${v.id} (${v.nodes}×): ${v.help}`,
 122:       );
 123:       for (const t of v.targets) console.log(`        @ ${t}`);
 124:     }
 125:   }
 126:   console.log(
 127:     `\n=== WCAG 2.2 AA axe scan: ${blocking} critical+serious node-violations across ${PAGES.length} pages ===`,
 128:   );
 129:   process.exit(blocking > 0 ? 1 : 0);
 130: };
 131: 
 132: run().catch((e) => {
 133:   console.error("scan failed:", e);
 134:   process.exit(2);
 135: });

 succeeded in 1093ms:
   1: // I-cd-013a (GH#609) — Tabs primitive wrapping @base-ui/react/tabs.
   2: //
   3: // Used by web/app/inspector/[runId]/inspector_view.tsx and any
   4: // downstream route that needs a tabbed layout. Each TabsContent
   5: // carries a `data-tab` attribute so Playwright e2e can assert tab
   6: // state explicitly per the Codex iter-2 P2 #3 directive.
   7: "use client";
   8: 
   9: import { Tabs as BaseTabs } from "@base-ui/react/tabs";
  10: import { forwardRef, type ComponentPropsWithoutRef } from "react";
  11: 
  12: import { cn } from "@/lib/utils";
  13: 
  14: export const Tabs = BaseTabs.Root;
  15: 
  16: export const TabsList = forwardRef<
  17:   HTMLDivElement,
  18:   ComponentPropsWithoutRef<typeof BaseTabs.List>
  19: >(({ className, ...props }, ref) => (
  20:   <BaseTabs.List
