  36:         // I-p2-019 (#758): map raw API errors to friendly copy (mirrors the
  37:         // /runs/[runId] G4 fix) — never leak "HTTP 500" / fn names to the user.
  38:         if (!cancelled) {
  39:           const raw = e.message.toLowerCase();
  40:           setError(
  41:             raw.includes("404")
  42:               ? "This run was not found. Check the URL or start a new run."
  43:               : "We couldn't load the knowledge graph right now. Please retry shortly.",
  44:           );
  45:         }
  46:       });
  47:     return () => {
  48:       cancelled = true;
  49:     };
  50:   }, [runId]);
