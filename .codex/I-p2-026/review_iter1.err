  52:   return (
  53:     <div className="flex min-h-screen flex-col">
  54:       <header className="border-border bg-background border-b">
  55:         <div className="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-4">
  56:           <div className="flex flex-col">
  57:             {/* I-p2-019 (#758): G2 — dropped the "F-snowball" dev-language. */}
  58:             <span className="text-muted-foreground text-xs font-medium tracking-widest uppercase">
  59:               Knowledge graph
  60:             </span>
  61:             <span className="text-foreground text-base font-semibold">
  62:               How this run&apos;s claims + sources connect
  63:             </span>
  64:           </div>
  65:           <Button
  66:             variant="outline"
  67:             nativeButton={false}
  68:             render={<Link href={`/inspector/${runId}`} />}
  69:           >
  70:             Back to Inspector
  71:           </Button>
  72:         </div>
  73:       </header>
  74: 
  75:       <main
  76:         data-testid="graph-page"
  77:         className="mx-auto flex w-full max-w-7xl flex-1 flex-col gap-4 px-6 py-6"
  78:       >
  79:         {/* I-p2-019 (#758): #750 ErrorState/LoadingState (design tokens +
