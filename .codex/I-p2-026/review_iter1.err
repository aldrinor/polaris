  94: 
  95: interface GraphSurfaceProps {
  96:   payload: GraphPayload;
  97:   runId: string;
  98: }
  99: 
 100: function GraphSurface({ payload, runId }: GraphSurfaceProps) {
 101:   const [state, adjacency, actions] = useGraphState(payload);
 102:   const searchInputRef = useRef<HTMLInputElement>(null);
 103:   const router = useRouter();
 104:   const [cy, setCy] = useState<cytoscape.Core | null>(null);
 105:   const inspectorHref = (id: string) =>
 106:     `/inspector/${runId}?${new URLSearchParams({ focused_node: id }).toString()}`;
 107: 
 108:   return (
 109:     <div className="flex flex-col gap-3">
 110:       <div className="flex flex-wrap items-center gap-2">
 111:         <Input
 112:           ref={searchInputRef}
 113:           type="search"
 114:           placeholder="Search nodes (press / to focus)…"
 115:           value={state.search_query}
 116:           onChange={(e) => actions.setSearchQuery(e.target.value)}
 117:           className="max-w-md"
 118:           aria-label="Search graph nodes"
 119:         />
 120:         <span className="text-muted-foreground text-xs">
 121:           {state.visible_node_ids.size}/{payload.elements.nodes.length} visible
 122:         </span>
 123:         <Button
 124:           variant="outline"
 125:           size="sm"
 126:           disabled={!state.selected_node_id}
 127:           onClick={() => {
 128:             if (state.selected_node_id)
 129:               router.push(inspectorHref(state.selected_node_id));
 130:           }}
 131:         >
 132:           Open Inspector
 133:         </Button>
 134:         <Button
 135:           variant="outline"
 136:           size="sm"
 137:           disabled={!state.selected_node_id}
 138:           onClick={() => {
 139:             if (!state.selected_node_id) return;
 140:             actions.setSnowballHighlight(
 141:               snowballNeighbors(payload, state.selected_node_id, 2),
 142:             );
 143:           }}
 144:         >
 145:           Expand snowball (2 hops)
 146:         </Button>
 147:         {state.snowball_highlight_ids && (
 148:           <Button
 149:             variant="ghost"
 150:             size="sm"
 151:             onClick={() => actions.setSnowballHighlight(null)}
 152:           >
 153:             Clear ({state.snowball_highlight_ids.size} nodes)
 154:           </Button>
 155:         )}
 156:         <GraphExportButtons cy={cy} payload={payload} />
 157:       </div>
 158:       <div className="grid gap-4 lg:grid-cols-[1fr_360px]">
 159:         <ClaimGraph
 160:           payload={payload}
 161:           selectedNodeId={state.selected_node_id}
 162:           searchQuery={state.search_query}
 163:           snowballHighlightIds={state.snowball_highlight_ids}
 164:           setSelectedNodeId={actions.setSelectedNodeId}
 165:           onCyReady={setCy}
 166:         />
 167:         <AccessibleGraphList
 168:           payload={payload}
 169:           state={state}
 170:           adjacency={adjacency}
 171:           runId={runId}
 172:           searchInputRef={searchInputRef}
 173:           setSelectedNodeId={actions.setSelectedNodeId}
 174:         />
 175:       </div>
 176:     </div>
 177:   );
 178: }

