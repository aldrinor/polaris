1327: export async function getRunGraph(runId: string): Promise<GraphPayload> {
1328:   const res = await authFetch(`${BACKEND_URL}/api/runs/${runId}/graph`);
1329:   if (!res.ok) {
1330:     const body = await res.text();
1331:     const err = new Error(
1332:       `getRunGraph(${runId}) HTTP ${res.status}: ${body}`,
1333:     ) as ApiError;
1334:     err.status = res.status;
1335:     throw err;
1336:   }
1337:   return res.json() as Promise<GraphPayload>;
1338: }
