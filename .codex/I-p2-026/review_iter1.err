 140: test.describe("WCAG 2.5.8 target-size sweep (F-28 — broader than axe)", () => {
 141:   // axe's target-size rule has loose overlap-detection; cycle-8 P1.1 and
 142:   // P1.4 surfaced multiple <button>/<label>/<a role="button"> surfaces
 143:   // that pass axe but fail strict WCAG 2.2 SC 2.5.8 AA (24x24 minimum).
 144:   // This sweep walks every clickable element + asserts ≥24x24 directly.
 145: 
 146:   test("Dashboard — all clickable targets ≥24x24", async ({ page }) => {
 147:     await page.goto("/dashboard", { waitUntil: "networkidle" });
 148:     const small = await page.evaluate(() => {
 149:       const results: Array<{
 150:         tag: string;
 151:         text: string;
 152:         w: number;
 153:         h: number;
 154:       }> = [];
 155:       // Exclude <label htmlFor=...> — labels paired with a form control
 156:       // delegate the hit target to the control itself (WCAG 2.5.8 "inline"
 157:       // exemption). The "browse files" label has no htmlFor (it wraps the
 158:       // hidden file input directly) so it remains in scope.
 159:       const sel =
 160:         'button, label:not([for]), [role="button"], [role="radio"], a[href]';
 161:       document.querySelectorAll(sel).forEach((el) => {
 162:         if (!(el instanceof HTMLElement)) return;
 163:         const r = el.getBoundingClientRect();
 164:         if (r.width === 0 || r.height === 0) return; // hidden / pre-render
 165:         if (r.width < 24 || r.height < 24) {
 166:           results.push({
 167:             tag: el.tagName,
 168:             text: (el.textContent || "").trim().slice(0, 60),
 169:             w: Math.round(r.width),
 170:             h: Math.round(r.height),
 171:           });
 172:         }
 173:       });
 174:       return results;
 175:     });
 176:     if (small.length > 0) {
 177:       throw new Error(
 178:         `WCAG 2.5.8 failures (${small.length} target(s) < 24x24):\n` +
 179:           small
 180:             .map((s) => `  - ${s.tag} "${s.text}" → ${s.w}x${s.h}px`)
 181:             .join("\n"),
 182:       );
 183:     }
 184:   });
