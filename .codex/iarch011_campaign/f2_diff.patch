+@contextlib.contextmanager
+def _advisory_entailment_disabled():
+    """Force ``PG_STRICT_VERIFY_ENTAILMENT=off`` for the duration of the ADVISORY basket
+    assembly, then restore the prior value (I-arch-011 F2b, #1268).
+
+    WHY: the per-member basket verify is ADVISORY (the module docstring +
+    ``_verify_member_in_isolation``'s docstring both state strict_verify is "never re-run as a
+    gate" here), yet it calls ``verify_sentence_provenance``, whose 6th-check entailment judge
+    defaults to ENFORCE and makes ONE serial LLM call per member. With F2a building the
+    priors-only basket over hundreds of members, that is the Q72/Q76/Q90 serial-entailment HANG,
+    re-armed. We disable ONLY the entailment 6th-check, ONLY for the advisory assembly, with a
+    SINGLE set/restore wrapped AROUND the whole ``_assemble_baskets`` call — the per-member
+    ThreadPoolExecutor is created AND joined inside that call, so the worker threads only READ
+    the off value during the window (no per-thread race; ``os.environ`` is process-global, not a
+    ContextVar, so the copied contexts see the same value).
+
+    FAITHFULNESS-NEUTRAL: the BINDING section gate is a DIFFERENT call path (``_run_section`` ->
+    ``strict_verify`` at render) and keeps ``enforce``, so every member this advisory pass surfaces
+    is still re-verified under entailment-ENFORCE before it can be cited. Disabling entailment here
+    can only make the advisory verdict MORE permissive (offer more candidates) — never relax the
+    binding gate that decides what actually renders. The credibility-pass entry runs on a worker
+    thread AFTER outline/Stage-1 and BEFORE Stage-2 section generation, so no binding strict_verify
+    runs concurrently with this window.
+    """
+    prev = os.environ.get("PG_STRICT_VERIFY_ENTAILMENT")
+    os.environ["PG_STRICT_VERIFY_ENTAILMENT"] = "off"
+    try:
+        yield
+    finally:
+        if prev is None:
+            os.environ.pop("PG_STRICT_VERIFY_ENTAILMENT", None)
+        else:
+            os.environ["PG_STRICT_VERIFY_ENTAILMENT"] = prev
+
