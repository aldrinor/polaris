+
+    async def spec_provider(_q, sourced):
+        dp = next(d for d in sourced
+                  if abs(float(d["value"]) - 2_000_000_000.0) < 1)
+        return {
+            "model_id": "tco", "title": "TCO",
+            "inputs": [
