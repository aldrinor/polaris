+    <Card data-testid="metadata-panel">
+      <CardHeader>
+        <CardTitle className="text-base">Bundle metadata</CardTitle>
+      </CardHeader>
+      <CardContent className="text-sm">
+        <dl className="grid grid-cols-1 gap-x-6 gap-y-2 md:grid-cols-[max-content,1fr]">
