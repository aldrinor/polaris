1038: /**
1039:  * Build + download a GPG-signed audit bundle for the given research chain.
1040:  *
1041:  * Returns a Blob of the audit_<id>.tar.gz on success. On HTTP 4xx/5xx
1042:  * with a structured error body, throws AuditBundleError with the .code
1043:  * field set so callers can show specific UX (e.g. "GPG signer not
1044:  * configured" vs "report verdict not success").
1045:  */
1046: export async function downloadAuditBundle(
1047:   decision: IntakeScopeDecision,
1048:   pool: EvidencePool,
1049:   report: VerifiedReport,
1050: ): Promise<Blob> {
1051:   const response = await authFetch(`${BACKEND_URL}/api/audit-bundle`, {
1052:     method: "POST",
1053:     headers: { "content-type": "application/json" },
1054:     body: JSON.stringify({ decision, pool, report }),
1055:   });
1056:   if (!response.ok) {
1057:     const detail = await response.json().catch(() => null);
1058:     const body = (detail?.detail ?? detail) as AuditBundleErrorBody | null;
1059:     if (body && body.error) {
1060:       throw new AuditBundleError(body);
1061:     }
1062:     throw new Error(`Audit bundle request failed: HTTP ${response.status}`);
1063:   }
1064:   return await response.blob();
1065: }
