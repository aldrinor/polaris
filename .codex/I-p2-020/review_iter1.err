   1: // I-p2-020 (#759) — Audit / export: the "take the proof with you" surface.
   2: //
   3: // Distinct from /inspector/[runId] (the evidence EXPLORER: per-claim proof
   4: // replay, evidence, reasoning). This is the COMPLIANCE/EXPORT artifact: the
   5: // signed-package integrity manifest (file hashes), the pipeline gate ledger,
   6: // the two-family provenance, and the download. Server component — every field
   7: // comes from the proven `loadBundle` path (same loader the inspector + the
   8: // /api/inspector_bundle/[runId] route use); no client JS needed (download is a
   9: // plain <a download> to that route).
  10: //
  11: // Honesty (LAW II): the canonical bundle ships WITHOUT manifest.yaml.asc (the
  12: // GPG seal was deliberately deferred — operator "skip the seal, build the real
  13: // proof"). So `signaturePresent` is false and the page says exactly that:
  14: // integrity manifest present, GPG signature pending sovereign signing. It never
  15: // claims a signature that isn't on disk.
  16: //
  17: // The richer per-gate audit log (corpus adequacy / approval / evaluator
  18: // rule-checks from AuditIrRun via GET /api/inspector/runs/{id}) is a documented
  19: // follow-up — that endpoint is used by no frontend yet, so building on it would
  20: // violate LAW II until it's verified live against the backend.
  21: 
  22: import Link from "next/link";
  23: 
  24: import { BundlePendingCta } from "@/components/inspector/bundle_pending_cta";
  25: import { Button } from "@/components/ui/button";
  26: import {
  27:   loadBundle,
  28:   type LoadedBundle,
  29:   type VerifiedReportShape,
  30: } from "@/lib/inspector_bundle_loader";
  31: import type { FileEntry } from "@/lib/signed_bundle";
  32: 
  33: interface AuditPageProps {
  34:   params: Promise<{ runId: string }>;
  35: }
  36: 
  37: const CONTENT_TYPE_LABEL: Record<string, string> = {
  38:   scope_decision: "Scope decision",
  39:   evidence_pool: "Evidence pool",
  40:   verified_report: "Verified report",
  41:   source_snapshot: "Source snapshot",
  42:   metadata: "Metadata",
  43:   reasoning_trace: "Reasoning trace",
  44: };
  45: 
  46: function pct(value: number): string {
  47:   return `${Math.round(value * 100)}%`;
  48: }
  49: 
  50: function shortHash(sha256: string): string {
  51:   return sha256.length > 16 ? `${sha256.slice(0, 16)}…` : sha256;
  52: }
  53: 
  54: function totalVerifiedSentences(report: VerifiedReportShape): number {
  55:   return report.sections.reduce(
  56:     (sum, section) => sum + section.verified_sentences.length,
  57:     0,
  58:   );
  59: }
  60: 
  61: interface GateRow {
  62:   gate: string;
  63:   pass: boolean;
  64:   detail: string;
  65: }
  66: 
  67: // The pipeline gate ledger, composed ONLY from fields that exist in the proven
  68: // signed-bundle verified_report. No fabricated gate fields.
  69: function buildGateLedger(report: VerifiedReportShape): GateRow[] {
  70:   const rows: GateRow[] = [
  71:     {
  72:       gate: "Pipeline verdict",
  73:       pass: report.pipeline_verdict === "success",
  74:       detail: report.pipeline_verdict,
  75:     },
  76:     {
  77:       gate: "Strict-verify (overall)",
  78:       pass: report.overall_verify_pass_rate >= report.verifier_pass_threshold,
  79:       detail: `${pct(report.overall_verify_pass_rate)} of sentences span-verified · threshold ${pct(report.verifier_pass_threshold)}`,
  80:     },
  81:     {
  82:       gate: "Two-family segregation",
  83:       pass: report.family_segregation_passed,
  84:       detail: `${report.generator_model} (generator) ≠ ${report.evaluator_model} (evaluator)`,
  85:     },
  86:   ];
  87:   for (const section of report.sections) {
  88:     rows.push({
  89:       gate: `Section: ${section.section_id}`,
  90:       pass: section.section_verify_pass_rate >= report.verifier_pass_threshold,
  91:       detail: `${pct(section.section_verify_pass_rate)} span-verified · ${section.verified_sentences.length} verified sentences`,
  92:     });
  93:   }
  94:   return rows;
  95: }
  96: 
  97: function StatusPill({ pass }: { pass: boolean }) {
  98:   return (
  99:     <span
 100:       className={
 101:         pass
 102:           ? "border-verified bg-verified/10 text-verified inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-semibold tracking-wide uppercase"
 103:           : "border-refusal bg-refusal/10 text-refusal inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-semibold tracking-wide uppercase"
 104:       }
 105:     >
 106:       {pass ? "Pass" : "Fail"}
 107:     </span>
 108:   );
 109: }
 110: 
 111: function MetaRow({ label, value }: { label: string; value: string }) {
 112:   return (
 113:     <div className="flex flex-col gap-0.5">
 114:       <span className="text-muted-foreground text-[10px] font-medium tracking-widest uppercase">
 115:         {label}
 116:       </span>
 117:       <span className="text-foreground text-sm break-words">{value}</span>
 118:     </div>
 119:   );
 120: }
 121: 
 122: function AuditExportBody({ bundle }: { bundle: LoadedBundle }) {
 123:   const { manifest, metadata, verifiedReport, signaturePresent, runId } =
 124:     bundle;
 125:   const gateLedger = buildGateLedger(verifiedReport);
 126:   const files: FileEntry[] = manifest.files;
 127:   const totalBytes = files.reduce((sum, f) => sum + f.size_bytes, 0);
 128: 
 129:   return (
 130:     <div className="flex flex-col gap-8">
 131:       {/* Integrity & provenance */}
 132:       <section className="border-border bg-card flex flex-col gap-4 rounded-lg border p-5">
 133:         <div className="flex flex-wrap items-start justify-between gap-3">
 134:           <h2 className="text-foreground text-sm font-semibold">
 135:             Integrity &amp; provenance
 136:           </h2>
 137:           {/* HONEST signature status — never claims a seal that isn't on disk. */}
 138:           {signaturePresent ? (
 139:             <span className="border-verified bg-verified/10 text-verified inline-flex items-center gap-1 rounded-full border px-2.5 py-1 text-[11px] font-semibold">
 140:               ⬡ GPG-signed (manifest.yaml.asc present)
 141:             </span>
 142:           ) : (
 143:             <span
 144:               className="border-border text-muted-foreground inline-flex items-center gap-1 rounded-full border px-2.5 py-1 text-[11px] font-medium"
 145:               title="The bundle ships with a SHA-256 integrity manifest now; the detached GPG signature is added once the sovereign Canadian signer is live."
 146:             >
 147:               ◌ Integrity manifest present · GPG signature pending
 148:             </span>
 149:           )}
 150:         </div>
 151:         <div className="grid grid-cols-2 gap-4 sm:grid-cols-3">
 152:           <MetaRow label="Bundle ID" value={manifest.bundle_id} />
 153:           <MetaRow label="Schema" value={`v${metadata.schema_version}`} />
 154:           <MetaRow label="POLARIS version" value={metadata.polaris_version} />
 155:           <MetaRow label="Generator model" value={metadata.generator_model} />
 156:           <MetaRow label="Evaluator model" value={metadata.evaluator_model} />
 157:           <MetaRow
 158:             label="Created (UTC)"
 159:             value={metadata.bundle_created_at_utc}
 160:           />
 161:         </div>
 162:       </section>
 163: 
 164:       {/* Pipeline gate ledger */}
 165:       <section className="flex flex-col gap-3">
 166:         <div className="flex flex-col gap-1">
 167:           <h2 className="text-foreground text-sm font-semibold">
 168:             Pipeline gate ledger
 169:           </h2>
 170:           <p className="text-muted-foreground text-xs">
 171:             Every gate this run cleared before any claim shipped. Composed from
 172:             the verified report in the bundle —{" "}
 173:             {totalVerifiedSentences(verifiedReport)} sentences span-verified
 174:             across {verifiedReport.sections.length} sections.
 175:           </p>
 176:         </div>
 177:         <div className="border-border overflow-x-auto rounded-lg border">
 178:           <table className="w-full text-left text-sm">
 179:             <thead className="border-border text-muted-foreground border-b text-[10px] tracking-widest uppercase">
 180:               <tr>
 181:                 <th className="px-4 py-2.5 font-medium">Gate</th>
 182:                 <th className="px-4 py-2.5 font-medium">Status</th>
 183:                 <th className="px-4 py-2.5 font-medium">Detail</th>
 184:               </tr>
 185:             </thead>
 186:             <tbody>
 187:               {gateLedger.map((row) => (
 188:                 <tr
 189:                   key={row.gate}
 190:                   className="border-border/60 border-b last:border-0"
 191:                 >
 192:                   <td className="text-foreground px-4 py-2.5 font-medium">
 193:                     {row.gate}
 194:                   </td>
 195:                   <td className="px-4 py-2.5">
 196:                     <StatusPill pass={row.pass} />
 197:                   </td>
 198:                   <td className="text-muted-foreground px-4 py-2.5">
 199:                     {row.detail}
 200:                   </td>
 201:                 </tr>
 202:               ))}
 203:             </tbody>
 204:           </table>
 205:         </div>
 206:       </section>
 207: 
 208:       {/* Integrity manifest — the file hash chain */}
 209:       <section className="flex flex-col gap-3">
 210:         <div className="flex flex-col gap-1">
 211:           <h2 className="text-foreground text-sm font-semibold">
 212:             Integrity manifest
 213:           </h2>
 214:           <p className="text-muted-foreground text-xs">
 215:             Every file in the package with its SHA-256. Re-hash the extracted
 216:             bundle and compare — any tampering breaks the hash.
 217:           </p>
 218:         </div>
 219:         <div className="border-border overflow-x-auto rounded-lg border">
 220:           <table className="w-full text-left text-sm">
 221:             <thead className="border-border text-muted-foreground border-b text-[10px] tracking-widest uppercase">
 222:               <tr>
 223:                 <th className="px-4 py-2.5 font-medium">File</th>
 224:                 <th className="px-4 py-2.5 font-medium">Type</th>
 225:                 <th className="px-4 py-2.5 text-right font-medium">Bytes</th>
 226:                 <th className="px-4 py-2.5 font-medium">SHA-256</th>
 227:               </tr>
 228:             </thead>
 229:             <tbody>
 230:               {files.map((f) => (
 231:                 <tr
 232:                   key={f.path}
 233:                   className="border-border/60 border-b last:border-0"
 234:                 >
 235:                   <td className="text-foreground px-4 py-2.5 font-mono text-xs">
 236:                     {f.path}
 237:                   </td>
 238:                   <td className="text-muted-foreground px-4 py-2.5 text-xs">
 239:                     {CONTENT_TYPE_LABEL[f.content_type] ?? f.content_type}
 240:                   </td>
 241:                   <td className="text-muted-foreground px-4 py-2.5 text-right font-mono text-xs">
 242:                     {f.size_bytes.toLocaleString()}
 243:                   </td>
 244:                   <td
 245:                     className="text-muted-foreground px-4 py-2.5 font-mono text-xs"
 246:                     title={f.sha256}
 247:                   >
 248:                     {shortHash(f.sha256)}
 249:                   </td>
 250:                 </tr>
 251:               ))}
 252:             </tbody>
 253:           </table>
 254:         </div>
 255:         <p className="text-muted-foreground text-[10px]">
 256:           {files.length} files · {totalBytes.toLocaleString()} bytes total
 257:         </p>
 258:       </section>
 259: 
 260:       {/* Export */}
 261:       <section className="border-border bg-card flex flex-col gap-3 rounded-lg border p-5">
 262:         <h2 className="text-foreground text-sm font-semibold">
 263:           Export the package
 264:         </h2>
 265:         <p className="text-muted-foreground text-xs">
 266:           Download the full audit package as JSON — scope decision, evidence
 267:           pool, verified report, source snapshots, reasoning trace and this
 268:           manifest. Hand it to a reviewer for offline verification.
 269:         </p>
 270:         <div className="flex flex-wrap gap-2">
 271:           <Button
 272:             nativeButton={false}
 273:             render={
 274:               <a
 275:                 href={`/api/inspector_bundle/${encodeURIComponent(runId)}`}
 276:                 download={`polaris_audit_${runId}.json`}
 277:               />
 278:             }
 279:           >
 280:             Download audit package (JSON)
 281:           </Button>
 282:           <Button
 283:             variant="outline"
 284:             nativeButton={false}
 285:             render={<Link href={`/inspector/${runId}`} />}
 286:           >
 287:             Open in Inspector
 288:           </Button>
 289:         </div>
 290:       </section>
 291:     </div>
 292:   );
 293: }
