   1: // I-p2-009 (#748): sovereignty proof panel + signed-bundle mark. Surfaces the
   2: // sovereignty + integrity story as VERIFIABLE facts, not a marketing badge.
   3: // HONESTY: never claims "cryptographically signed" without a signature, never
   4: // "air-gapped", never asserts the two-family invariant passed without the real
   5: // family_segregation_passed field. Renders only fields present.
   6: import { BadgeCheck, ShieldCheck } from "lucide-react";
   7: 
   8: interface SovereigntyPanelProps {
   9:   generatorModel?: string | null;
  10:   evaluatorModel?: string | null;
  11:   /** verified_report.family_segregation_passed — the real source of truth. */
  12:   familySegregationPassed?: boolean;
  13:   polarisVersion?: string | null;
  14:   bundleId?: string | null;
  15:   bundleCreatedAt?: string | null;
  16:   /** metadata.schema_version / manifest.bundle_version — rendered only if present. */
  17:   schemaVersion?: string | null;
  18:   /** Number of integrity-hashed files in the manifest (each carries a sha256). */
  19:   fileCount?: number | null;
  20:   /** A real detached signature — only then is "cryptographically signed" shown. */
  21:   signature?: string | null;
  22: }
  23: 
  24: function Row({ label, value }: { label: string; value: string }) {
  25:   return (
  26:     <div className="flex items-baseline justify-between gap-3 text-xs">
  27:       <span className="text-muted-foreground">{label}</span>
  28:       <span className="text-foreground font-mono">{value}</span>
  29:     </div>
  30:   );
  31: }
  32: 
  33: export function SovereigntyPanel({
  34:   generatorModel,
  35:   evaluatorModel,
  36:   familySegregationPassed,
  37:   polarisVersion,
  38:   bundleId,
  39:   bundleCreatedAt,
  40:   schemaVersion,
  41:   fileCount,
  42:   signature,
  43: }: SovereigntyPanelProps) {
  44:   return (
  45:     <section
  46:       data-testid="sovereignty-panel"
  47:       className="border-border bg-card flex flex-col gap-4 rounded-md border p-4 text-sm"
  48:     >
  49:       {/* (a) Sovereignty — the honest shell wording */}
  50:       <div className="flex items-start gap-2">
  51:         <ShieldCheck
  52:           aria-hidden
  53:           className="text-primary mt-0.5 h-4 w-4 shrink-0"
  54:         />
  55:         <div>
  56:           <p className="text-foreground font-medium">Canadian-hosted</p>
  57:           {/* I-p2-023 (#762): HONEST — dropped the false present-tense "no
  58:               external AI vendor". Production LLM inference currently routes via
  59:               OpenRouter (US, transitional, disclosed in /transparency); the
  60:               sovereign Canadian GPU cluster is the target, not yet live. */}
  61:           <p className="text-muted-foreground text-xs">
  62:             Hosted in Canada; public sources fetched via logged Canadian egress.
  63:             LLM inference is currently routed via OpenRouter (US, disclosed)
  64:             pending the sovereign Canadian GPU cluster.
  65:           </p>
  66:         </div>
  67:       </div>
  68: 
  69:       {/* (b) Two-family invariant — passed claim ONLY from the real field */}
  70:       {(generatorModel || evaluatorModel) && (
  71:         <div className="border-border flex flex-col gap-1 border-t pt-3">
  72:           <div className="flex items-center justify-between gap-2">
  73:             <p className="text-foreground font-medium">Two-family invariant</p>
  74:             {familySegregationPassed === true ? (
  75:               <span className="bg-verified/10 text-verified border-verified/30 inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-[11px] font-medium">
  76:                 <BadgeCheck aria-hidden className="h-3 w-3 shrink-0" />
  77:                 Verified
  78:               </span>
  79:             ) : familySegregationPassed === false ? (
  80:               <span className="bg-muted text-foreground border-border inline-flex items-center rounded-full border px-2 py-0.5 text-[11px] font-medium">
  81:                 Not verified
  82:               </span>
  83:             ) : null}
  84:           </div>
  85:           {generatorModel && <Row label="Generator" value={generatorModel} />}
  86:           {evaluatorModel && <Row label="Evaluator" value={evaluatorModel} />}
  87:         </div>
  88:       )}
  89: 
  90:       {/* (c) Bundle integrity / signed mark — honest about what's proven */}
  91:       {(bundleId || polarisVersion || bundleCreatedAt || schemaVersion) && (
  92:         <div className="border-border flex flex-col gap-1 border-t pt-3">
  93:           <p className="text-foreground mb-1 font-medium">Signed bundle</p>
  94:           {bundleId && <Row label="Bundle" value={bundleId} />}
  95:           {schemaVersion && <Row label="Schema" value={schemaVersion} />}
  96:           {polarisVersion && <Row label="POLARIS" value={polarisVersion} />}
  97:           {bundleCreatedAt && <Row label="Created" value={bundleCreatedAt} />}
  98:           {signature ? (
  99:             <p className="text-verified mt-1 text-[11px]">
 100:               Cryptographically signed.
 101:             </p>
 102:           ) : fileCount != null ? (
 103:             <p className="text-muted-foreground mt-1 text-[11px]">
 104:               Integrity-hashed · {fileCount} files, sha256 per file
 105:               (tamper-evident).
 106:             </p>
 107:           ) : null}
 108:         </div>
 109:       )}
 110:     </section>
 111:   );
 112: }

