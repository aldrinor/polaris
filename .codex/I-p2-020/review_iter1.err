 295: export default async function AuditExportPage({ params }: AuditPageProps) {
 296:   const { runId } = await params;
 297:   const bundle = await loadBundle(runId);
 298: 
 299:   // Chromeless route (own header + <main>) — see app_shell_gate.tsx.
 300:   return (
 301:     <div className="flex min-h-screen flex-col">
 302:       <header className="border-border bg-background border-b">
 303:         <div className="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-4">
 304:           <div className="flex flex-col">
 305:             <span className="text-muted-foreground text-xs font-medium tracking-widest uppercase">
 306:               Audit &amp; export
 307:             </span>
 308:             <span className="text-foreground text-base font-semibold">
 309:               Take the proof with you
 310:             </span>
 311:           </div>
 312:           <Button
 313:             variant="outline"
 314:             nativeButton={false}
 315:             render={<Link href={`/inspector/${runId}`} />}
 316:           >
 317:             Back to Inspector
 318:           </Button>
 319:         </div>
 320:       </header>
 321: 
 322:       <main
 323:         data-testid="audit-export-page"
 324:         className="mx-auto w-full max-w-5xl flex-1 px-6 py-8"
 325:       >
 326:         {bundle === null ? (
 327:           <BundlePendingCta runId={runId} />
 328:         ) : (
 329:           <AuditExportBody bundle={bundle} />
 330:         )}
 331:       </main>
 332:     </div>
 333:   );
 334: }

