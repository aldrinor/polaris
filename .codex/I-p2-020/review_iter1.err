  98: // ---------------------------------------------------------------------------
  99: 
 100: export interface BundleMetadata {
 101:   polaris_version: string;
 102:   generator_model: string;
 103:   evaluator_model: string;
 104:   bundle_created_at_utc: string;
 105:   schema_version: typeof BUNDLE_VERSION;
 106: }
 107: 
 108: // ---------------------------------------------------------------------------
 109: // Parsers
 110: // ---------------------------------------------------------------------------
 111: 
 112: /** Parse a `manifest.yaml` text into a typed `BundleManifest`.
 113:  *
 114:  * Validation is structural (presence of required fields + bundle_version
 115:  * literal); deeper conformance (path traversal, SHA256 matching, content
 116:  * schema validity) lives in the Python `check_bundle_conformance`. */
 117: export function parseManifest(yamlText: string): BundleManifest {
 118:   const parsed = yaml.load(yamlText);
 119:   if (parsed === null || typeof parsed !== "object" || Array.isArray(parsed)) {
 120:     throw new Error("manifest.yaml does not parse to a YAML mapping");
 121:   }
 122:   const m = parsed as Partial<BundleManifest>;
 123:   if (m.bundle_version !== BUNDLE_VERSION) {
 124:     throw new Error(
 125:       `bundle_version ${m.bundle_version} != frozen ${BUNDLE_VERSION}`,
 126:     );
 127:   }
 128:   for (const required of [
 129:     "bundle_id",
 130:     "decision_id",
 131:     "pool_id",
 132:     "report_id",
 133:     "generator_model",
 134:     "polaris_version",
 135:     "files",
 136:     "bundle_created_at_utc",
 137:   ] as const) {
 138:     if (m[required] === undefined || m[required] === null) {
 139:       throw new Error(`manifest.yaml missing required field: ${required}`);
 140:     }
 141:   }
 142:   if (!Array.isArray(m.files)) {
 143:     throw new Error("manifest.yaml `files` must be an array");
 144:   }
 145:   return m as BundleManifest;
 146: }
 147: 
 148: /** Parse a `reasoning_trace.jsonl` text body into a list of records.
 149:  *
 150:  * One JSON object per non-empty line; blank lines are skipped. Malformed
 151:  * lines throw to surface bundle corruption at the source. */
 152: export function parseReasoningTraceJsonl(text: string): ReasoningTraceRecord[] {
 153:   const out: ReasoningTraceRecord[] = [];
 154:   const lines = text.split(/\r?\n/);
 155:   for (let i = 0; i < lines.length; i += 1) {
 156:     const line = lines[i];
 157:     if (line.trim() === "") continue;
 158:     let record: unknown;
 159:     try {
 160:       record = JSON.parse(line);
 161:     } catch (err) {
 162:       throw new Error(
 163:         `reasoning_trace.jsonl line ${i + 1} is not valid JSON: ${(err as Error).message}`,
 164:       );
 165:     }
 166:     if (
 167:       typeof record !== "object" ||
 168:       record === null ||
 169:       Array.isArray(record)
 170:     ) {
 171:       throw new Error(
 172:         `reasoning_trace.jsonl line ${i + 1} is not a JSON object`,
 173:       );
 174:     }
 175:     out.push(record as ReasoningTraceRecord);
 176:   }
 177:   return out;
 178: }
 179: 
 180: /** Helper: filter `BundleManifest.files` by ContentType. */
 181: export function filesByContentType(
 182:   manifest: BundleManifest,
 183:   contentType: ContentType,
 184: ): FileEntry[] {
 185:   return manifest.files.filter((f) => f.content_type === contentType);
 186: }

