   1: // I-cd-013a (GH#609) — server-only bundle loader.
   2: //
   3: // Imported by web/app/inspector/[runId]/page.tsx and
   4: // web/app/api/inspector_bundle/[runId]/route.ts. Returns the parsed
   5: // canonical fixture data for runId === "v1-canonical" or
   6: // "v1-canonical-success"; returns null for any other runId (the page
   7: // renders a BundlePendingCTA in that case).
   8: //
   9: // Real-bundle backend wiring lands at I-B-08 (Seq 20); offline
  10: // fallback (in-browser bundle render) at I-B-09 (Seq 21). This module
  11: // is the swappable seam — same function signature, different data
  12: // path in each follow-up issue.
  13: 
  14: import { promises as fs } from "node:fs";
  15: import path from "node:path";
  16: 
  17: import {
  18:   type BundleManifest,
  19:   type BundleMetadata,
  20:   type ReasoningTraceRecord,
  21:   parseManifest,
  22:   parseReasoningTraceJsonl,
  23: } from "@/lib/signed_bundle";
  24: 
  25: // I-p2-p0 (#789): the canonical fixture ships in web/public/canonical_bundles/
  26: // (Dockerfile COPYs public → /app/public; cwd=/app at runtime), so it resolves
  27: // in dev, the standalone harness, AND the prod container — unlike the old
  28: // process.cwd()/../tests/fixtures path, which only existed in dev → live 500.
  29: const FIXTURE_ROOT = path.join(process.cwd(), "public", "canonical_bundles");
  30: 
  31: export interface LoadedBundle {
  32:   runId: string;
  33:   manifest: BundleManifest;
  34:   scopeDecision: unknown;
  35:   evidencePool: unknown;
  36:   verifiedReport: VerifiedReportShape;
  37:   metadata: BundleMetadata;
  38:   reasoningTrace: ReasoningTraceRecord[];
  39:   sources: Record<string, string>;
  40:   /** True iff manifest.yaml.asc exists and is non-empty on disk for this bundle.
  41:    * Derived during load — NOT a manifest field. Codex diff iter-1 P2. */
  42:   signaturePresent: boolean;
  43: }
  44: 
  45: export interface VerifiedReportShape {
  46:   report_id: string;
  47:   pool_id: string;
  48:   decision_id: string;
  49:   sections: VerifiedReportSectionShape[];
  50:   overall_verify_pass_rate: number;
  51:   verifier_pass_threshold: number;
  52:   pipeline_verdict: string;
  53:   generator_model: string;
  54:   evaluator_model: string;
  55:   family_segregation_passed: boolean;
  56:   started_at_utc: string;
  57:   finished_at_utc: string;
  58:   latency_ms: number;
  59:   cost_usd: number;
  60:   /** The research question this brief answered (real-run bundles). */
  61:   research_question?: string;
  62: }
  63: 
  64: export interface VerifiedReportSectionShape {
  65:   section_id: string;
  66:   section_verify_pass_rate: number;
  67:   verified_sentences: VerifiedSentenceShape[];
  68:   [extra: string]: unknown;
  69: }
  70: 
  71: export interface VerifiedSentenceShape {
  72:   section_id: string;
  73:   sentence_text: string;
  74:   provenance_tokens: string[];
  75:   verifier_pass: boolean;
  76:   [extra: string]: unknown;
  77: }
  78: 
  79: const KNOWN_FIXTURES: Record<string, string> = {
  80:   "v1-canonical": "v1_canonical",
  81:   "v1-canonical-success": "v1_canonical_success",
  82: };
  83: 
  84: export async function loadBundle(runId: string): Promise<LoadedBundle | null> {
  85:   // typeof guard (not `!relPath`): runId could be an Object.prototype name
  86:   // (toString / __proto__ / constructor) → KNOWN_FIXTURES[runId] returns a
  87:   // function/object → path.join would throw before the try → user-triggerable
  88:   // 500. A non-string lookup → null → BundlePendingCta. (Codex iter-2 P1.)
  89:   const relPath = KNOWN_FIXTURES[runId];
  90:   if (typeof relPath !== "string") return null;
  91:   const dir = path.join(FIXTURE_ROOT, relPath);
  92: 
  93:   try {
  94:     const manifestRaw = await fs.readFile(
  95:       path.join(dir, "manifest.yaml"),
  96:       "utf-8",
  97:     );
  98:     const manifest = parseManifest(manifestRaw);
  99: 
 100:     const scopeDecision = await readJson(dir, manifest, "scope_decision");
 101:     const evidencePool = await readJson(dir, manifest, "evidence_pool");
 102:     const verifiedReport = (await readJson(
 103:       dir,
 104:       manifest,
 105:       "verified_report",
 106:     )) as VerifiedReportShape;
 107: 
 108:     // metadata.json is selected by EXPLICIT PATH per the v1.0 freeze;
 109:     // multiple files may carry content_type=metadata (e.g. REVIEWER_README.md
 110:     // also flagged metadata in the active producer).
 111:     const metadataEntry = manifest.files.find(
 112:       (f) => f.content_type === "metadata" && f.path === "metadata.json",
 113:     );
 114:     if (!metadataEntry) {
 115:       throw new Error(
 116:         `bundle ${runId}: manifest has no entry with path=metadata.json and content_type=metadata`,
 117:       );
 118:     }
 119:     const metadata = JSON.parse(
 120:       await fs.readFile(path.join(dir, "metadata.json"), "utf-8"),
 121:     ) as BundleMetadata;
 122: 
 123:     const reasoningTraceEntry = manifest.files.find(
 124:       (f) => f.content_type === "reasoning_trace",
 125:     );
 126:     const reasoningTrace = reasoningTraceEntry
 127:       ? parseReasoningTraceJsonl(
 128:           await fs.readFile(path.join(dir, reasoningTraceEntry.path), "utf-8"),
 129:         )
 130:       : [];
 131: 
 132:     const sources: Record<string, string> = {};
 133:     for (const entry of manifest.files) {
 134:       if (entry.content_type !== "source_snapshot") continue;
 135:       sources[entry.path] = await fs.readFile(
 136:         path.join(dir, entry.path),
 137:         "utf-8",
 138:       );
 139:     }
 140: 
 141:     // Signature presence check (Codex diff iter-1 P2): mirror the conformance
 142:     // requirement — manifest.yaml.asc MUST exist and be non-empty for a v1.0
 143:     // bundle. The UI surfaces this boolean transparently; cryptographic
 144:     // verification belongs to operator-side `gpg --verify` tooling.
 145:     let signaturePresent = false;
 146:     try {
 147:       const stat = await fs.stat(path.join(dir, "manifest.yaml.asc"));
 148:       signaturePresent = stat.isFile() && stat.size > 0;
 149:     } catch {
 150:       signaturePresent = false;
 151:     }
 152: 
 153:     return {
 154:       runId,
 155:       manifest,
 156:       scopeDecision,
 157:       evidencePool,
 158:       verifiedReport,
 159:       metadata,
 160:       reasoningTrace,
 161:       sources,
 162:       signaturePresent,
 163:     };
 164:   } catch (err) {
 165:     // Graceful: a missing/unreadable/malformed bundle renders the pending
 166:     // state (BundlePendingCta), NEVER a 500. (#789 P0 — the centerpiece must
 167:     // not crash the page.)
 168:     console.error(`[inspector] bundle load failed for ${runId}:`, err);
 169:     return null;
 170:   }
 171: }
 172: 
 173: async function readJson(
 174:   dir: string,
 175:   manifest: BundleManifest,
 176:   contentType: "scope_decision" | "evidence_pool" | "verified_report",
 177: ): Promise<unknown> {
 178:   const entry = manifest.files.find((f) => f.content_type === contentType);
 179:   if (!entry) {
 180:     throw new Error(
 181:       `bundle: manifest has no entry of content_type=${contentType}`,
 182:     );
 183:   }
 184:   const body = await fs.readFile(path.join(dir, entry.path), "utf-8");
 185:   return JSON.parse(body);
 186: }

