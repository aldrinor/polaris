   8: // Real-bundle backend wiring lands at I-B-08 (Seq 20); offline fallback
   9: // at I-B-09 (Seq 21). For now `loadBundle` returns the canonical fixtures
  10: // for runId "v1-canonical" and "v1-canonical-success".
  11: 
  12: import { BundlePendingCta } from "@/components/inspector/bundle_pending_cta";
  13: import { loadBundle } from "@/lib/inspector_bundle_loader";
  14: import { filesByContentType } from "@/lib/signed_bundle";
