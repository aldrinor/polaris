  21: 
  22: export default async function InspectorPage({ params }: InspectorPageProps) {
  23:   const { runId } = await params;
  24:   const bundle = await loadBundle(runId);
  25: 
  26:   if (bundle === null) {
  27:     return <BundlePendingCta runId={runId} />;
