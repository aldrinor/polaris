+      touchSessionRef.current = true;
+      clearHoverDebounce();
+      clearTouchAutoClose();
+      setOpen(true);
+      touchAutoCloseRef.current = window.setTimeout(() => {
+        touchAutoCloseRef.current = null;
+        touchSessionRef.current = false;
+        setOpen(false);
+      }, TOUCH_AUTO_CLOSE_MS);
+    },
