+    accounts_path = tmp_path / "static_accounts.yaml"
+    reviewer_hash = bcrypt.using(rounds=4).hash("reviewer_pw")
+    admin_hash = bcrypt.using(rounds=4).hash("admin_pw")
+    accounts_path.write_text(
