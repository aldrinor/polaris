+                claim_id=claim.claim_id,
+                claim=claim.claim_text,
+                evidence_documents=claim.evidence_documents,
+                severity=claim.severity,
+                s0_categories=claim.s0_categories,
+                model_slugs=model_slugs,
+                timestamp=timestamp,
+            )
