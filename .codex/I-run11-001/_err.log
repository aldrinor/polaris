class TemplateAffinityClassifier(Protocol):
    """Classifier interface: given a query + candidate slugs,
    return (best_slug or None, confidence)."""

    def classify(
        self,
        query: str,
        candidate_slugs: tuple[str, ...],
    ) -> ClassifierVerdict:
        ...


