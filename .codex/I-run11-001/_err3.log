def run_four_role_seam(
    transport: RoleTransport,
    *,
    run_dir: Path,
    timestamp: str,
    four_role_input_builder: FourRoleBundleBuilder | None = None,
    four_role_inputs: FourRoleEvaluationInputs | None = None,
    multi: object = None,
    template: object = None,
    slug: str | None = None,
