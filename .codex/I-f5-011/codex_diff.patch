+import { expect, test } from "@playwright/test";
+
+const N = 200;
+const PICK_COUNT = 10;
+const SEED = "polaris-i-f5-011";
+
+// xmur3 string-hash → 32-bit seed (public-domain implementation).
+function xmur3(str: string): () => number {
+  let h = 1779033703 ^ str.length;
+  for (let i = 0; i < str.length; i++) {
+    h = Math.imul(h ^ str.charCodeAt(i), 3432918353);
+    h = (h << 13) | (h >>> 19);
+  }
+  return () => {
+    h = Math.imul(h ^ (h >>> 16), 2246822507);
+    h = Math.imul(h ^ (h >>> 13), 3266489909);
+    h ^= h >>> 16;
+    return h >>> 0;
+  };
+}
+
+// sfc32 PRNG (public-domain) seeded from 4 32-bit ints.
+function sfc32(a: number, b: number, c: number, d: number): () => number {
+  return () => {
+    a >>>= 0;
+    b >>>= 0;
+    c >>>= 0;
+    d >>>= 0;
+    let t = (a + b) | 0;
+    a = b ^ (b >>> 9);
+    b = (c + (c << 3)) | 0;
+    c = (c << 21) | (c >>> 11);
+    d = (d + 1) | 0;
+    t = (t + d) | 0;
+    c = (c + t) | 0;
+    return (t >>> 0) / 4294967296;
+  };
+}
+
+function pickIndices(): number[] {
+  const seed_fn = xmur3(SEED);
+  const rand = sfc32(seed_fn(), seed_fn(), seed_fn(), seed_fn());
+  const all = Array.from({ length: N }, (_, i) => i);
+  for (let i = N - 1; i > 0; i--) {
+    const j = Math.floor(rand() * (i + 1));
+    [all[i], all[j]] = [all[j], all[i]];
+  }
+  return all.slice(0, PICK_COUNT);
+}
+
+test("AI agent navigates 10 random sentences; each opens evidence within 1s", async ({
+  page,
+}) => {
+  await page.goto(`/sentence_hover_test/stress?n=${N}`);
+  await expect(page.getByTestId("verified-report-view")).toBeVisible();
+  await expect(page.getByTestId("kept-sentence")).toHaveCount(N);
+
+  const picks = pickIndices();
+  expect(picks).toHaveLength(PICK_COUNT);
+
+  for (const i of picks) {
+    const elapsed_ms = await page.evaluate(async (idx) => {
+      const target = document.querySelector(
+        `[data-sentence-id="sec_stress:${idx}"]`,
+      ) as HTMLElement | null;
+      if (!target) throw new Error(`sentence row ${idx} not found`);
+      const t0 = performance.now();
+      target.click();
+      await new Promise<void>((resolve) => {
+        const observer = new MutationObserver(() => {
+          if (
+            document.querySelector('[data-testid="sentence-inspector-sheet"]')
+          ) {
+            observer.disconnect();
+            resolve();
+          }
+        });
+        observer.observe(document.body, { childList: true, subtree: true });
+        if (
+          document.querySelector('[data-testid="sentence-inspector-sheet"]')
+        ) {
+          observer.disconnect();
+          resolve();
+        }
+      });
+      return performance.now() - t0;
+    }, i);
+
+    expect(elapsed_ms, `iter ${i}: click → Sheet`).toBeLessThan(1000);
+
+    // Each kept stress sentence cites src-(i mod 50) → inspector-source-0
+    // should always be present. Tolerate alternates for robustness.
+    const sheet = page.getByTestId("sentence-inspector-sheet");
+    await expect(sheet).toBeVisible();
+    const evidence_count = await page
+      .locator(
+        '[data-testid^="inspector-source-"], [data-testid="inspector-paywalled-0"], [data-testid="inspector-synthesis-claim"]',
+      )
+      .count();
+    expect(evidence_count, `iter ${i}: evidence card present`).toBeGreaterThan(
+      0,
+    );
+
+    // Per Codex iter-1 P1: close + assert detach before next iteration.
+    await page.keyboard.press("Escape");
+    await expect(page.getByTestId("sentence-inspector-sheet")).toHaveCount(0);
+  }
+});
