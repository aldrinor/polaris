         return True
+    # I-wire-016 #1338 gap-fill (affiliation-glued / title+affiliation / author-attribution-phrase) —
+    # the precision-safe masthead classes that leaked past the legacy categories.
+    if _contains_iwire016_gap_furniture(s):
