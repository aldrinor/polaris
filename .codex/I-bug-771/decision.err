.\outputs\codex_findings\dr_output_pass_14_v27\_codex_stdout.txt:1217:outputs\audits\v25\_codex_stdout.txt:2743:"C:\\Program Files\\PowerShell\\7\\pwsh.exe" -Command 'rg -n "SURPASS|SURMOUNT|Jastreboff|Frias|Rosenstock|Ludvik|Lancet|JAMA|NEJM|Health Canada|FDA|EMA|NICE|Mounjaro|Zepbound|contradiction|Limitations|mechanism|Mechanism" outputs/full_scale_v25/clinical/clinical_tirzepatide_t2dm/report.md outputs/full_scale_v25/clinical/clinical_tirzepatide_t2dm/bibliography.json outputs/full_scale_v25/clinical/clinical_tirzepatide_t2dm/manifest.json' in C:\POLARIS
