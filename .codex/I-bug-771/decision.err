scripts\inject_test_trace.py:707:                 {"id": "s4", "title": "Membrane Technologies: RO and Nanofiltration", "order": 4, "description": "Rejection rates, energy, and concentrate management", "evidence_count": 15, "perspectives": ["technical", "environmental"]},
scripts\inject_test_trace.py:708:                 {"id": "s5", "title": "Emerging Destructive Technologies", "order": 5, "description": "Electrochemical, sonochemical, and advanced oxidation", "evidence_count": 8, "perspectives": ["technical"]},
