+# "than usual" no longer match.
 _COMPARATIVE_ARM_RE = re.compile(
     r"\b(?:than|versus|vs\.?|compared\s+(?:to|with))\s+"
-    r"(?:placebo|control|standard\s+care|usual\s+care|\w{3,})\b",
+    r"(?:"
