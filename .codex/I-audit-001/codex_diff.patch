+def _write_bibliography(tmp_path, entries):
+    import json as _json
+    p = tmp_path / "bibliography.json"
+    p.write_text(_json.dumps(entries), encoding="utf-8")
+    return p
+
+
+def _write_pool(tmp_path, entries):
+    import json as _json
+    p = tmp_path / "pool.json"
+    p.write_text(_json.dumps(entries), encoding="utf-8")
+    return p
+
