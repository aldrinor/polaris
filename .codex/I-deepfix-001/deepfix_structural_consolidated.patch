+
+# A provenance token: ``[#ev:<evidence_id>:<start>-<end>]`` (the shape strict_verify parses).
+_EV_TOKEN_RE = re.compile(r"\[#ev:[^\]]*\]")
+_EV_SPAN_RE = re.compile(r"\[#ev:(?P<ev_id>[A-Za-z0-9_]+):(?P<start>\d+)-(?P<end>\d+)\]")
