+    r"|\bup\s+to\b|\bas\s+(?:much|many)\s+as\b|\bover\s+half\b"
+    r"|\bif\b|\bassum(?:e|es|ed|ing)\b|\bprovided\b"
+    r"|\bscenario\b|\bhypothetical(?:ly)?\b"
