+# empty-round case it exists to prevent. `PG_SCOPE_KEEP_BEST_N=0` reverts to the
+# legacy drop-to-empty.
+_KEEP_BEST_N_ENV = "PG_SCOPE_KEEP_BEST_N"
+_DEFAULT_KEEP_BEST_N = 1
+
