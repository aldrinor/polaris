+            emitted.append(_emit_unit(unit, markers))
+        if not emitted:
+            continue
+        lines.append(f"{number}. {' '.join(emitted)}")
+        number += 1
+
+    if not lines:
+        return ""
+    return f"## {_EVIDENCE_BASE_TITLE}\n\n" + "\n".join(lines)
