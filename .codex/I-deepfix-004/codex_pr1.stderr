[7m[0m  # Fetch-time relevance rerank + per-sub-query reservation (I-meta-002-q1d #951/#943)[0m
[7m[0m  # ─────────────────────────────────────────────────────────────────────────────[0m
[7m[0m  [0m
[7m[0m  # Pure-lexical, no-model relevance: stopword-filtered content-word overlap of a[0m
[7m[0m  # candidate's (title+snippet) against the research question. NO embedder / no model[0m
[7m[0m  # load (§8.4) — sentence-transformers/CUDA are never touched on the ranking path.[0m
[7m[0m  _RERANK_STOPWORDS = frozenset({[0m
[7m[0m      "the", "a", "an", "and", "or", "but", "is", "are", "was", "were", "of", "in",[0m
[7m[0m      "on", "at", "to", "for", "with", "by", "from", "as", "that", "this", "these",[0m
[7m[0m      "those", "it", "its", "be", "been", "what", "which", "who", "how", "why",[0m
[7m[0m      "when", "where", "we", "our", "their", "between", "into", "about", "than",[0m
[7m[0m  })[0m
