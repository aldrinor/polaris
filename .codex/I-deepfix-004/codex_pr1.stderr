[7m[0m      head = content[:_snap_end_to_word_boundary(content, head_chars)][0m
[7m[0m  [0m
[7m[0m      # Find all decimal positions in the full content[0m
[7m[0m      positions: list[tuple[int, int]] = [][0m
[7m[0m      for m in _DECIMAL_PATTERN.finditer(content):[0m
[7m[0m          start = max(0, m.start() - window_chars // 2)[0m
[7m[0m          end = min(len(content), m.end() + window_chars // 2)[0m
[7m[0m          positions.append((start, end))[0m
[7m[0m  [0m
[7m[0m      # De-overlap: merge adjacent windows that touch each other[0m
[7m[0m      positions.sort()[0m
