[7m[0m      backoff = _CRAWL4AI_CIRCUIT_BREAKER_BACKOFF[0m
[7m[0m      if backoff <= 1.0 or generation <= 1:[0m
[7m[0m          cooldown = base[0m
[7m[0m      else:[0m
[7m[0m          cooldown = base * (backoff ** (generation - 1))[0m
[7m[0m      return min(cooldown, _CRAWL4AI_CIRCUIT_BREAKER_MAX_COOLDOWN)[0m
