[7m[0m              os.getenv([0m
[7m[0m                  "PG_JINA_PREAMBLE_MAX_CHARS",[0m
[7m[0m                  str(_JINA_PREAMBLE_MAX_CHARS_DEFAULT),[0m
[7m[0m              )[0m
[7m[0m          )[0m
[7m[0m          if marker.start() <= preamble_max:[0m
[7m[0m              text = text[marker.end():][0m
[7m[0m  [0m
[7m[0m      text = strip_web_boilerplate(text)[0m
[7m[0m      # Remove any residual inline reader marker tokens (a second embedded preamble[0m
[7m[0m      # deep in the body that the head-window drop + whole-line strip both miss).[0m
[7m[0m      text = _JINA_INLINE_TOKEN_RE.sub(" ", text)[0m
