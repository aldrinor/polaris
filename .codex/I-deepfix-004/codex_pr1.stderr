694	    # Signal 2 — ISSN masthead AND contents/editorial vocab co-occur (both required).
695	    if _FRONT_MATTER_ISSN_RE.search(body) and any(
696	        marker in low for marker in _FRONT_MATTER_CONTENTS_VOCAB
697	    ):
