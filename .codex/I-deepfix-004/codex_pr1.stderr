[7m[0m      # byte-for-byte. The faithfulness engine (strict_verify / NLI / span-grounding)[0m
[7m[0m      # is untouched.[0m
[7m[0m      from src.tools.access_bypass import dehyphenate_line_wraps  # noqa: PLC0415[0m
[7m[0m      content = dehyphenate_line_wraps(content)[0m
[7m[0m      if len(content) <= head_chars:[0m
