[7m[0m  [0m
[7m[0m  def _rerank_content_tokens(text: str) -> set[str]:[0m
[7m[0m      """Lowercase content-word tokens (3+ chars, stopword-filtered). Pure lexical."""[0m
[7m[0m      toks = re.findall(r"[A-Za-z][A-Za-z\-]{2,}", (text or "").lower())[0m
[7m[0m      return {t for t in toks if t not in _RERANK_STOPWORDS}[0m
[7m[0m  [0m
[7m[0m  [0m
      NO B4-private canary, so the scorer contract cannot drift (Codex B4 iter-2 P1).
  
      Each candidate is shaped into the row-dict B1's `_row_embed_text` reads. That
>     helper embeds the row's ``statement`` + ``[7mdirect_quote[0m`` fields, so a[0m
[7m[0m      candidate's text surface (`snippet_text` = title + snippet — the SAME surface[0m
[7m[0m      the lexical scorer reads) is mapped onto ``statement``. B1 then returns[0m
[7m[0m      ``{row_index -> max cosine over {research_question} ∪ {sub_queries}}`` clamped[0m
[7m[0m      to [0, 1], or ``None`` (embedder unavailable / scoring failed / no anchor).[0m
[7m[0m  [0m
[7m[0m      Returns a per-candidate score list aligned to ``candidates`` (in [0, 1]), or[0m
[7m[0m      ``None`` — the caller falls back LOUDLY to the legacy lexical cut on ``None``[0m
[7m[0m      (LAW II: no silent keep-all). The import is INSIDE this function so the OFF path[0m
[7m[0m      (which never calls it) never imports the embedder / evidence_selector."""[0m
[7m[0m      try:[0m
[7m[0m          from src.polaris_graph.retrieval.evidence_selector import ([0m
[7m[0m              _semantic_relevance_scores,[0m
[7m[0m          )[0m
[7m[0m      except Exception as exc:  # import-path failure[0m
[7m[0m          logger.warning([0m
[7m[0m              "[live_retriever] B4 relevance scorer import failed (%s) — falling "[0m
[7m[0m              "back LOUDLY to the lexical count-cut.",[0m
[7m[0m              str(exc)[:200],[0m
[7m[0m          )[0m
[7m[0m          return None[0m
[7m[0m      # Shape each candidate as the row-dict B1's `_row_embed_text` reads: it embeds[0m
>     # `statement` + `[7mdirect_quote[0m`, so the candidate's title+snippet surface goes[0m
[7m[0m      # onto `statement` (an empty-snippet candidate therefore embeds to ~0.0, exactly[0m
[7m[0m      # as B1 scores a row with no text — no B4-private bypass).[0m
[7m[0m      rows = [[0m
[7m[0m          {"statement": (getattr(c, "snippet_text", "") or "")}[0m
[7m[0m          for c in candidates[0m
[7m[0m      ][0m
[7m[0m      score_map = _semantic_relevance_scores(research_question, sub_queries, rows)[0m
[7m[0m      if score_map is None:[0m
[7m[0m          # B1's None = embedder unavailable / scoring failed / no usable anchor.[0m
[7m[0m          return None[0m
[7m[0m      # `_semantic_relevance_scores` keys by row index; project back to list order.[0m
[7m[0m      return [float(score_map.get(i, 0.0)) for i in range(len(candidates))][0m
