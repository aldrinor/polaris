[7m[0m      for s, e in positions:[0m
[7m[0m          if merged and s <= merged[-1][1]:[0m
[7m[0m              merged[-1] = (merged[-1][0], max(merged[-1][1], e))[0m
[7m[0m          else:[0m
[7m[0m              merged.append((s, e))[0m
[7m[0m  [0m
[7m[0m      # Drop windows already fully inside the head[0m
[7m[0m      merged = [(s, e) for s, e in merged if e > head_chars][0m
          # I-wire-014 (#1327): snap each decimal-window's START forward and END back
          # to whole-word boundaries, so a chunk neither BEGINS mid-word right after a
