+# verifier. This is a CAP on the reservation, not a token starvation — it never lowers any max_tokens.
+_RESERVE_CONTEXT_TOKENS = max(1, int(os.getenv("PG_FOUR_ROLE_RESERVE_CONTEXT_TOKENS", "400000")))
