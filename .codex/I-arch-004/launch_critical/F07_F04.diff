+# ───────────────────────── F07: fail-closed faithfulness-slate preflight ─────────────────────────
+
+def _load_sweep_module():
+    """Import the sweep module fresh so module-level env reads are not cached across tests."""
+    import scripts.run_honest_sweep_r3 as mod
