# POLARIS — Environment Variables Template
# =========================================
# Copy to .env and fill in values. .env is gitignored.
#
# The live code references ~400 env vars in total (see
# docs/pipeline_audit_context/08_env_var_inventory.md for the full
# list). This template covers the REQUIRED vars and the most commonly
# tuned ones. Most PG_* tunables have sensible defaults in code.

# ─────────────────────────────────────────────────────────────────
# REQUIRED for pipeline A (honest-rebuild sweep)
# ─────────────────────────────────────────────────────────────────

# OpenRouter gateway (all generator + evaluator calls)
OPENROUTER_API_KEY=sk-or-v1-...

# Primary web search
SERPER_API_KEY=...

# Academic search (strongly recommended; pipeline will run without it
# but retrieval quality drops significantly)
SEMANTIC_SCHOLAR_API_KEY=...

# ─────────────────────────────────────────────────────────────────
# OPTIONAL API integrations
# ─────────────────────────────────────────────────────────────────

# Exa search (improves retrieval coverage)
EXA_API_KEY=...
PG_EXA_ENABLED=1

# Firecrawl (JS-rendered page fetching)
FIRECRAWL_API_KEY=...
PG_FIRECRAWL_ENABLED=1

# Jina Reader (markdown conversion)
JINA_API_KEY=...
PG_JINA_ENABLED=1

# OpenAI (pipeline B UI features; NOT required for pipeline A)
OPENAI_API_KEY=...

# Fireworks (historical generator; NOT required for current pair)
FIREWORKS_API_KEY=...

# OpenAlex (academic metadata; email required per API terms)
PG_OPENALEX_EMAIL=your.email@example.com
PG_OPENALEX_ENABLED=1

# Crossref (DOI resolution; email per polite-use guidelines)
CROSSREF_EMAIL=your.email@example.com

# I-meta-007c: OPEN-ACCESS resolver wired into the LIVE retrieval loop.
# When AccessBypass returns a stub/empty/paywalled result for a candidate
# carrying a DOI, the resolver tries Unpaywall v2 best-OA URL (fetched via the
# already-budgeted AccessBypass) and, when a PMID is present, a PubMed EFetch
# abstract fallback BEFORE giving up. Fail-OPEN: any resolver error returns ""
# and retrieval falls through to its existing path. Both backends are free.
# PG_ENABLE_LIVE_OA_RESOLVER: master on/off (default "1"; "0" disables).
PG_ENABLE_LIVE_OA_RESOLVER=1
# PG_UNPAYWALL_EMAIL: email passed to the Unpaywall v2 API (ToS requirement,
# not auth). Defaults to a placeholder; set a real address before live runs.
PG_UNPAYWALL_EMAIL=your.email@example.com

# ─────────────────────────────────────────────────────────────────
# MODEL PAIR (two-family constraint enforced at construction)
# ─────────────────────────────────────────────────────────────────

# Current pair (re-pinned 2026-05-19 per I-cd-009 / GH#624; Carney
# demo lock). Generator DeepSeek V4 Pro 1.6T (49B active MoE) + evaluator
# Gemma 4 31B-it (Google lineage, two-family segregation). See
# openrouter_client.py for HHEM benchmarks and two-family justification;
# see docs/models/evaluator_pick.md + docs/models/serving_engine_pick.md
# for the Codex-APPROVE'd pick history.
PG_GENERATOR_MODEL=deepseek/deepseek-v4-pro
PG_EVALUATOR_MODEL=google/gemma-4-31b-it

# Escape hatch for fine-tunes; use only if you know the family
# classification is wrong
# PG_GENERATOR_FAMILY_OVERRIDE=deepseek
# PG_EVALUATOR_FAMILY_OVERRIDE=gemma

OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─────────────────────────────────────────────────────────────────
# BUDGET + LIMITS (pipeline A)
# ─────────────────────────────────────────────────────────────────

# Hard cap per sweep (BudgetExceededError at threshold)
PG_MAX_COST_PER_RUN=5.00

# Evidence cap passed to generator (caps per-section evidence)
PG_LIVE_MAX_EV_TO_GEN=20

# LLM call timeout / retry
PG_LLM_TIMEOUT_SECONDS=120
PG_LLM_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────
# INVARIANT THRESHOLDS (pipeline A hardness)
# ─────────────────────────────────────────────────────────────────

# B-1 content-word overlap (lower = looser; default 2 is the
# tested floor. 1 allows single-noun-overlap fabrications.)
PG_PROVENANCE_MIN_CONTENT_OVERLAP=2

# NLI verifier opt-in (expensive; adds an independent check)
PG_NLI_ENABLED=0
# PG_NLI_MODEL=MiniCheck-Flan-T5-Large

# ─────────────────────────────────────────────────────────────────
# OUTPUT + LOGGING
# ─────────────────────────────────────────────────────────────────

PG_LIVE_TRACE_DIR=logs
PG_COST_LEDGER_PATH=logs/pg_cost_ledger.jsonl
PG_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────
# PIPELINE B (UI) — required only if running the FastAPI server
# ─────────────────────────────────────────────────────────────────

POLARIS_AUTH_ENABLED=1
POLARIS_AUTH_SECRET=change-me-to-a-random-string
POLARIS_AUTH_SALT=change-me-to-a-different-random-string
POLARIS_ADMIN_PASSWORD=...
POLARIS_CORS_ORIGINS=http://localhost:8000
POLARIS_DEPLOYMENT_MODE=cloud

# Graph version (v1 / v2 / v3)
PG_GRAPH_VERSION=v3
PG_V2_ENABLED=0

# ─────────────────────────────────────────────────────────────────
# DOCKER / DEPLOYMENT
# ─────────────────────────────────────────────────────────────────

POLARIS_VERSION=0.9.0
POLARIS_PORT=8000
CHROMA_PORT=8100

# v6 stack (docker-compose.v6.yml) — Caddy TLS / reverse proxy (I-rdy-015).
# For a local `docker compose -f docker-compose.v6.yml up`, localhost makes
# Caddy use its internal CA — no public domain or ACME needed. A real
# deploy overrides POLARIS_DOMAIN to the public hostname and sets
# POLARIS_ACME_EMAIL (see infra/vexxhost/.env.example).
POLARIS_DOMAIN=localhost
POLARIS_ACME_EMAIL=

# ─────────────────────────────────────────────────────────────────
# SOVEREIGN MODE (optional; self-hosted search + LLM)
# ─────────────────────────────────────────────────────────────────

# SEARXNG_PORT=8888
# VLLM_API_KEY=...
# VLLM_BASE_URL=http://localhost:8200/v1
# VLLM_MODEL=ebircak/gemma-4-31B-it-4bit-W4A16-AWQ
# Load with --quantization compressed-tensors server-side (NOT --quantization awq)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=...

# ─────────────────────────────────────────────────────────────────
# I-wire-001 WAVE-2 WINNERS (default-OFF; byte-identical when unset)
# ─────────────────────────────────────────────────────────────────
#
# W3 — SEARCH-FUSION WRRF (#1310). Gather per-engine RANKED candidate
# lists, weighted-reciprocal-rank-fuse on those ranks, THEN URL-dedup,
# so a high-authority source one engine buries is lifted by another
# engine's strong rank. Deterministic (no LLM). The same flag also
# enables the bounded-parallel retrieval-backend fan-out it feeds.
# PG_SEARCH_FUSION_WRRF=1
# PG_SEARCH_FUSION_WRRF_K=60                # RRF smoothing constant (>0)
# PG_SEARCH_FUSION_WRRF_DEFAULT_WEIGHT=1.0  # weight for an unlisted engine
# Per-engine weights (engine:weight comma list); academic/registry can
# outweigh generic web search so a NEJM hit beats a marketing page:
# PG_SEARCH_FUSION_WRRF_WEIGHTS=serper:1.0,openalex_search:1.2,s2:1.1,europe_pmc:1.2,arxiv:1.1
# PG_RETRIEVAL_BACKEND_WORKERS=6            # bounded backend fan-out cap
#
# W2 — CONTENT-RELEVANCE JUDGE (#1311). Post-fetch / pre-tier. Qwen3-
# Reranker-0.6B (always-on, GPU-first) scores each fetched passage's
# relevance to the research question; GLM-5.2 escalates ONLY on the
# reranker's ambiguous band. Off-topic passages are DOWN-WEIGHTED +
# disclosed (§-1.3 weight-not-filter) — NEVER dropped. Faithfulness
# engine untouched.
# PG_CONTENT_RELEVANCE_JUDGE=1
# PG_CONTENT_RELEVANCE_WORKERS=12           # bounded GLM-escalation fan-out
# PG_CONTENT_RELEVANCE_BAND_LOW=0.05        # below => confident junk (demote)
# PG_CONTENT_RELEVANCE_BAND_HIGH=0.70       # above => confident relevant
# PG_CONTENT_RELEVANCE_DEMOTE_WEIGHT=0.25   # kept-at-low-weight (never 0/drop)
# PG_CONTENT_RELEVANCE_PASSAGE_CHARS=2000   # head-window fed to the reranker
# PG_CONTENT_RELEVANCE_MAX_LENGTH=4096      # reranker max token length
# PG_CONTENT_RELEVANCE_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
# PG_CONTENT_RELEVANCE_DEVICE=              # blank=auto (cuda if available, else cpu)
# The GLM escalation reuses the relevance-judge transport; under the
# all-GLM single-family campaign it needs the documented same-family override:
# PG_RELEVANCE_ALLOW_SAME_FAMILY=1
#
# W5 — CREDIBILITY LLM-TIERING (#1311). GLM-5.2 classifies each source DIRECTLY into
# the T1-T7 tier scheme, repairing the rules-floor's weak T7-social / T2-synthesis
# recall. Tier is a per-citation WEIGHT, never a drop; ANY judge_error/timeout falls
# back to the deterministic rules-floor (§-1.3). Bounded-parallel per-source fan-out.
PG_CONSOLIDATION_NLI=0          # W7 — NLI-entailment claim consolidation (basket multi-citation), default-OFF
PG_CREDIBILITY_LLM_TIERING=0    # W5 — GLM-5.2 per-source T1-T7 tiering (rules-floor fallback), default-OFF
PG_ADEQUACY_CRAG=0              # W8 — CRAG corpus-adequacy gate (correct/ambiguous/incorrect), default-OFF
# PG_TIER_LLM_WORKERS=10        # W5 bounded-parallel per-source tiering fan-out cap

# ─────────────────────────────────────────────────────────────────
# SCOPE — intent_frame winner (I-wire-001 W1, board row 1)
# ─────────────────────────────────────────────────────────────────
# A SINGLE GLM-5.2 call decomposes a long/confusing/multi-part prompt
# into a typed IntentFrame {questions[], domain, clarification_needed[]}
# and runs ADVISORY in front of the deterministic run_scope_gate — it
# does NOT replace or relax the binding scope gate or touch protocol.json
# (faithfulness engine untouched). Default-OFF = byte-identical legacy
# (frame never built, GLM never called, $0). When ON it is FAIL-CLOSED:
# an empty/None/zero-question decomposition raises IntentFrameError so a
# silent no-op aborts rather than shipping legacy under a wired claim.
PG_SCOPE_INTENT_FRAME=0          # W1 — advisory GLM-5.2 intent decomposition, default-OFF
# PG_SCOPE_INTENT_FRAME_MAX_QUESTIONS=10        # cap on decomposed sub-questions
# PG_SCOPE_INTENT_FRAME_MAX_CLARIFICATIONS=6    # cap on clarification items

# ─────────────────────────────────────────────────────────────────
# COMPOSITION — floor_abstractive winner (I-wire-001 W6, board row 12)
# ─────────────────────────────────────────────────────────────────
# The locked composition winner "floor_abstractive" (composite 20.55,
# beats all rivals p<0.05) IS the production abstractive writer
# (src/polaris_graph/generator/abstractive_writer.py, I-beatboth-005
# #1282), used as the per-basket writer_fn of _compose_section_per_basket.
# It is ALREADY wired flag-gated default-OFF at the caller seam
# multi_section_generator.py:3950-3974 — there is NO separate
# "floor_abstractive" flag (a second knob for one effect is a §-1.3
# anti-knob). To ACTIVATE the winner, set ALL THREE:
#   PG_VERIFIED_COMPOSE=1          -> reach the verified-compose branch
#   PG_ABSTRACTIVE_WRITER=1        -> the abstractive writer is the producer
#   PG_STRICT_VERIFY_ENTAILMENT=enforce  -> fail-closed activation guard
# OFF (any unset) => byte-identical to the deterministic composer.
# PG_VERIFIED_COMPOSE=0
# PG_ABSTRACTIVE_WRITER=0
# PG_STRICT_VERIFY_ENTAILMENT=off
#
# Abstractive-writer tuning (all have safe code defaults; LAW VI). The
# writer is a GENERATOR-role GLM-5.2 call that rephrases each verified
# span into clean declarative prose carrying the EXACT provenance token;
# every sentence re-passes the UNCHANGED verify_sentence_provenance, and
# a fabrication degrades to the verbatim K-span (faithfulness FROZEN).
# PG_ABSTRACTIVE_WRITER_MODEL=                 # default: generator-role slug, else z-ai/glm-5.2
# PG_ABSTRACTIVE_WRITER_MAX_RETRIES=1          # 2 total attempts (RARR-style revise on failure)
# PG_ABSTRACTIVE_WRITER_MAX_TOKENS=32768       # §9.1.8 MAX = full GLM-5.2 provider cap (2048 STARVED -> empty)
# PG_ABSTRACTIVE_WRITER_REASONING_MAX_TOKENS=  # UNSET => effort=high governs (§9.1.8); a fixed cap suppresses effort
# PG_ABSTRACTIVE_WRITER_CONCURRENCY=8          # BOUNDED per-basket fan-out (never unbounded; OOM/429). PROVEN: 23 baskets complete at 8 (177s) and 3 (197s); the wall-deadline is the completion guarantee, not the concurrency value.
# PG_ABSTRACTIVE_WRITER_TEMPERATURE=0.2        # low — faithful rephrase, not creative
# PG_ABSTRACTIVE_WRITER_CALL_DEADLINE_S=120    # FINITE per-call deadline -> force-close to K-span
# PG_ABSTRACTIVE_WRITER_WALL_DEADLINE_S=720    # FINITE OUTER wall on the WHOLE pre-pass -> abandon stuck baskets to K-span (never infinite; I-arch-007 wall+abandon). =worst-case makespan ceil(23/8)*2*120 so healthy baskets are never abandoned under uniform slowness.
# Per-section composition is BOUNDED by the existing PG_PARALLEL_SECTIONS
# semaphore (caller default 3) — no new section-worker knob is added.
# PG_PARALLEL_SECTIONS=3

# ─────────────────────────────────────────────────────────────────
# CLINICAL-PDF EXTRACTOR SELECTOR (I-wire-001/W4 #1313)
# ─────────────────────────────────────────────────────────────────
# Selector for the PDF -> text extractor in access_bypass._extract_pdf_text.
#   unset / "docling" -> current Docling-first -> PyMuPDF path (byte-identical).
#   "mineru25"        -> MinerU 2.5 GPU VLM (validated winner 0.9852 / TEDS #1)
#                        first, with Docling as the DISCLOSED CPU fallback when
#                        no GPU / mineru unavailable. GPU-first per the wiring
#                        standard point 2; the CPU fallback is LOUD, never silent.
# PG_CLINICAL_PDF_EXTRACTOR=docling
# MinerU 2.5 backend. Default vlm-transformers = verified in-process, no
# separate server, GPU-local (MinerU README + arXiv 2509.22186). Alternatives:
# vlm-vllm-engine / vlm-vllm-async-engine (higher throughput, more CUDA-sensitive),
# vlm-http-client (remote mineru-api via PG_MINERU25_SERVER_URL). All VLM backends
# require a GPU; no GPU -> LOUD Docling fallback.
# PG_MINERU25_BACKEND=vlm-transformers
# Validated winner model is opendatalab/MinerU2.5-2509-1.2B. do_parse has no model
# param; MinerU resolves it from the model source below. Keep huggingface to pin
# the official winner weights (modelscope = CN mirror; local = pre-downloaded dir).
# PG_MINERU25_MODEL_SOURCE=huggingface
# Device mode for MinerU (GPU-first). cuda forces GPU; the no-GPU case is already
# screened upstream and falls back to Docling before this is read.
# PG_MINERU25_DEVICE_MODE=cuda
# Document language hint passed to MinerU (improves OCR/layout on non-English).
# PG_MINERU25_LANG=en
# Optional remote mineru-api server URL (leave empty for in-process local).
# PG_MINERU25_SERVER_URL=
# Finite-generous per-PDF timeout (seconds) for the GPU VLM extract — never
# infinite; on timeout it falls back LOUDLY to Docling.
# PG_MINERU25_TIMEOUT_S=300
# NOTE (combined point-9 run): in-process vlm-transformers loads the VLM per
# call; under high PG_FETCH_EXTRACT_WORKERS concurrency that risks GPU OOM. For
# the throughput run, prefer a singleton/server (PG_MINERU25_BACKEND=vlm-http-client
# + PG_MINERU25_SERVER_URL) so one resident model serves all fetch workers.

# ─────────────────────────────────────────────────────────────────
# EXTENDED TUNABLES
# ─────────────────────────────────────────────────────────────────
# See docs/pipeline_audit_context/08_env_var_inventory.md for the
# full list of ~400 env vars referenced by the codebase. Most have
# sensible defaults; touch only if you understand the tradeoffs.
