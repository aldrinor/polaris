# POLARIS — Environment Variables Template
# =========================================
# Copy to .env and fill in values. .env is gitignored.
#
# The live code references ~400 env vars in total (see
# docs/pipeline_audit_context/08_env_var_inventory.md for the full
# list). This template covers the REQUIRED vars and the most commonly
# tuned ones. Most PG_* tunables have sensible defaults in code.

# ─────────────────────────────────────────────────────────────────
# REQUIRED for pipeline A (honest-rebuild sweep)
# ─────────────────────────────────────────────────────────────────

# OpenRouter gateway (all generator + evaluator calls)
OPENROUTER_API_KEY=sk-or-v1-...

# Primary web search
SERPER_API_KEY=...

# Academic search (strongly recommended; pipeline will run without it
# but retrieval quality drops significantly)
SEMANTIC_SCHOLAR_API_KEY=...

# ─────────────────────────────────────────────────────────────────
# OPTIONAL API integrations
# ─────────────────────────────────────────────────────────────────

# Exa search (improves retrieval coverage)
EXA_API_KEY=...
PG_EXA_ENABLED=1

# Firecrawl (JS-rendered page fetching)
FIRECRAWL_API_KEY=...
PG_FIRECRAWL_ENABLED=1

# Jina Reader (markdown conversion)
JINA_API_KEY=...
PG_JINA_ENABLED=1

# OpenAI (pipeline B UI features; NOT required for pipeline A)
OPENAI_API_KEY=...

# Fireworks (historical generator; NOT required for current pair)
FIREWORKS_API_KEY=...

# OpenAlex (academic metadata; email required per API terms)
PG_OPENALEX_EMAIL=your.email@example.com
PG_OPENALEX_ENABLED=1

# Crossref (DOI resolution; email per polite-use guidelines)
CROSSREF_EMAIL=your.email@example.com

# ─────────────────────────────────────────────────────────────────
# MODEL PAIR (two-family constraint enforced at construction)
# ─────────────────────────────────────────────────────────────────

# Current pair (re-pinned 2026-05-09 per I-bug-091; reverted from V4 Pro
# generator after live BEAT-BOTH showed CoT-style output incompatible
# with strict_verify provenance-token requirement). See openrouter_client.py
# for verified HHEM benchmarks, two-family justification, and revert
# rationale. Switch back to V4 Pro via PG_GENERATOR_MODEL env var.
PG_GENERATOR_MODEL=deepseek/deepseek-v3.2-exp
PG_EVALUATOR_MODEL=google/gemma-4-31b-it

# Escape hatch for fine-tunes; use only if you know the family
# classification is wrong
# PG_GENERATOR_FAMILY_OVERRIDE=deepseek
# PG_EVALUATOR_FAMILY_OVERRIDE=qwen

OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-v3.2-exp
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─────────────────────────────────────────────────────────────────
# BUDGET + LIMITS (pipeline A)
# ─────────────────────────────────────────────────────────────────

# Hard cap per sweep (BudgetExceededError at threshold)
PG_MAX_COST_PER_RUN=5.00

# Evidence cap passed to generator (caps per-section evidence)
PG_LIVE_MAX_EV_TO_GEN=20

# LLM call timeout / retry
PG_LLM_TIMEOUT_SECONDS=120
PG_LLM_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────
# INVARIANT THRESHOLDS (pipeline A hardness)
# ─────────────────────────────────────────────────────────────────

# B-1 content-word overlap (lower = looser; default 2 is the
# tested floor. 1 allows single-noun-overlap fabrications.)
PG_PROVENANCE_MIN_CONTENT_OVERLAP=2

# NLI verifier opt-in (expensive; adds an independent check)
PG_NLI_ENABLED=0
# PG_NLI_MODEL=MiniCheck-Flan-T5-Large

# ─────────────────────────────────────────────────────────────────
# OUTPUT + LOGGING
# ─────────────────────────────────────────────────────────────────

PG_LIVE_TRACE_DIR=logs
PG_COST_LEDGER_PATH=logs/pg_cost_ledger.jsonl
PG_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────
# PIPELINE B (UI) — required only if running the FastAPI server
# ─────────────────────────────────────────────────────────────────

POLARIS_AUTH_ENABLED=1
POLARIS_AUTH_SECRET=change-me-to-a-random-string
POLARIS_AUTH_SALT=change-me-to-a-different-random-string
POLARIS_ADMIN_PASSWORD=...
POLARIS_CORS_ORIGINS=http://localhost:8000
POLARIS_DEPLOYMENT_MODE=cloud

# Graph version (v1 / v2 / v3)
PG_GRAPH_VERSION=v3
PG_V2_ENABLED=0

# ─────────────────────────────────────────────────────────────────
# DOCKER / DEPLOYMENT
# ─────────────────────────────────────────────────────────────────

POLARIS_VERSION=0.9.0
POLARIS_PORT=8000
CHROMA_PORT=8100

# ─────────────────────────────────────────────────────────────────
# SOVEREIGN MODE (optional; self-hosted search + LLM)
# ─────────────────────────────────────────────────────────────────

# SEARXNG_PORT=8888
# VLLM_API_KEY=...
# VLLM_BASE_URL=http://localhost:8200/v1
# VLLM_MODEL=meta-llama/Llama-3.1-70B-Instruct
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=...

# ─────────────────────────────────────────────────────────────────
# EXTENDED TUNABLES
# ─────────────────────────────────────────────────────────────────
# See docs/pipeline_audit_context/08_env_var_inventory.md for the
# full list of ~400 env vars referenced by the codebase. Most have
# sensible defaults; touch only if you understand the tradeoffs.
