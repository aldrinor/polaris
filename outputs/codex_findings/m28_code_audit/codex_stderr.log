 324: 
 325: def run_domain_backends(
 326:     *,
 327:     domain: str,
 328:     research_question: str,
 329:     amplified_queries: list[str] | None = None,
 330:     max_hits_per_backend: int = PG_DOMAIN_MAX_HITS,
 331: ) -> DomainBackendResult:
 332:     """Run all applicable domain backends for the given domain.
 333: 
 334:     For each domain, returns a merged list of SearchCandidate that the
 335:     caller can concatenate with the generic Serper+S2 retrieval.
 336:     Fail-open: backends that raise return empty lists.
 337:     """
 338:     queries: list[str] = [research_question]
 339:     if amplified_queries:
 340:         queries.extend(amplified_queries[:3])   # cap amplified count
 341: 
 342:     candidates: list[SearchCandidate] = []
 343:     used: list[str] = []
 344:     per: dict[str, int] = {}
 345: 
 346:     def _run(name: str, fn) -> None:
 347:         nonlocal candidates, used, per
 348:         try:
 349:             got: list[SearchCandidate] = []
 350:             for q in queries:
 351:                 got.extend(fn(q, limit=max_hits_per_backend))
 352:                 if len(got) >= max_hits_per_backend * 2:
 353:                     break
 354:             # Dedup by URL
 355:             seen_urls = {c.url for c in candidates}
 356:             new = [c for c in got if c.url and c.url not in seen_urls]
 357:             candidates.extend(new)
 358:             used.append(name)
 359:             per[name] = len(new)
 360:         except Exception as exc:
 361:             logger.warning("[domain_backends] %s failed: %s", name, exc)
 362:             per[name] = 0
