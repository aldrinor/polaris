   1: """M-28 Fix #1 (2026-04-20): regulatory-anchor query expansion.
   2: 
   3: DR audit pass 7 head-to-head vs ChatGPT DR + Gemini 3.1 Pro DR exposed
   4: that V17 had ZERO regulatory-agency URLs in its bibliography while both
   5: tier-1 competitors cited FDA labels (accessdata.fda.gov), EMA SmPC
   6: (ema.europa.eu), Health Canada monographs (hres.ca), etc. Codex pass 6
   7: independently flagged this when V13 had to fall back to a Facebook post
   8: for the FDA boxed warning because no FDA source was retrieved.
   9: 
  10: This module adds a small, generalizable expansion step: when the scope
  11: template for the current domain carries a `regulatory_anchors` list,
  12: emit one extra amplified query per anchor of the form
  13: `{base_question} site:{anchor}`. That makes Serper / S2 hit
  14: authoritative governance sources without any hard-coded agency list
  15: in Python — every domain controls its own anchors in its YAML template.
  16: 
  17: Generalization constraint (user mandate 2026-04-20): fixes must work
  18: beyond the tirzepatide/T2D clinical query. This module:
  19:   - Has ZERO hard-coded domain or agency names.
  20:   - Returns [] when anchors list is missing or empty (backwards compat).
  21:   - Treats `regulatory_anchors` as an arbitrary list of URL hosts;
  22:     the template author chooses (clinical → FDA/EMA, policy →
  23:     Federal Register, due-diligence → SEC, energy → EPA, etc.).
  24: 
  25: Design:
  26:   - Caller (run_honest_sweep_r3.py) loads the scope template once and
  27:     calls `expand_regulatory_queries(question, domain)` to get the
  28:     extra queries, merges them into the amplified list.
  29:   - The live retriever does not know about regulatory anchors; the
  30:     extra queries travel through as regular amplified queries and go
  31:     through the same scope-validator de-drift + Serper/S2 fanout.
  32: """
  33: from __future__ import annotations
  34: 
  35: import logging
  36: from typing import Any
  37: 
  38: logger = logging.getLogger("polaris_graph.regulatory_expander")
  39: 
  40: 
  41: def _extract_anchors(template: dict[str, Any] | None) -> list[str]:
  42:     """Pull the `regulatory_anchors` list from a loaded scope template.
  43: 
  44:     Returns an empty list for missing / malformed / empty configuration.
  45:     Trims whitespace, skips non-string entries and empties.
  46:     """
  47:     if not isinstance(template, dict):
  48:         return []
  49:     raw = template.get("regulatory_anchors")
  50:     if not isinstance(raw, list):
  51:         return []
  52:     anchors: list[str] = []
  53:     for entry in raw:
  54:         if not isinstance(entry, str):
  55:             continue
  56:         stripped = entry.strip().lower()
  57:         # Reject entries that look like full URLs — the Serper `site:`
  58:         # operator expects a host. "https://fda.gov/path" would produce
  59:         # an invalid query. Keep only host-shaped tokens.
  60:         if not stripped or "/" in stripped or " " in stripped:
  61:             continue
  62:         anchors.append(stripped)
  63:     # Deduplicate while preserving declared order.
  64:     seen: set[str] = set()
  65:     unique: list[str] = []
  66:     for a in anchors:
  67:         if a not in seen:
  68:             seen.add(a)
  69:             unique.append(a)
  70:     return unique
  71: 
  72: 
  73: def expand_regulatory_queries(
  74:     question: str,
  75:     template: dict[str, Any] | None,
  76: ) -> list[str]:
  77:     """Return `site:{anchor}` queries derived from the scope template.
  78: 
  79:     Args:
  80:         question: the user's research question (or any base query text).
  81:         template: the loaded scope template dict (or None if none set).
  82: 
  83:     Returns:
  84:         A list of `{question} site:{anchor}` strings, one per configured
  85:         anchor. Empty list when the template has no `regulatory_anchors`
  86:         key, an empty list, or when the question is empty/whitespace.
  87: 
  88:     This function is pure and deterministic — no network, no state.
  89:     """
  90:     base = (question or "").strip()
  91:     if not base:
  92:         return []
  93:     anchors = _extract_anchors(template)
  94:     if not anchors:
  95:         return []
  96:     queries = [f"{base} site:{anchor}" for anchor in anchors]
  97:     logger.info(
  98:         "[regulatory_expander] emitted %d anchor queries for base=%r",
  99:         len(queries), base[:60],
 100:     )
 101:     return queries

