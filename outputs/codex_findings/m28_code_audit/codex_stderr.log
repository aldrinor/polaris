   1: """
   2: Scope-protocol query validator — HONEST-REBUILD Phase 2e.
   3: 
   4: Validates that amplified search queries stay within the pre-registered
   5: protocol's research scope. Drops queries that have drifted off-topic
   6: before they waste retrieval budget.
   7: 
   8: WHY THIS EXISTS (PG_LB_SA_02_CONTENT_AUDIT Section E-04):
   9: The pre-rebuild pipeline amplified a single research question into
  10: 10-25 search variants using an LLM. Some variants drifted:
  11:   original: "efficacy of semaglutide for weight loss"
  12:   amplified: "Japan national health insurance elderly care coverage"
  13: 
  14: These drifted queries pulled in the junk that Phase 2d's post-fetch
  15: off-topic filter then had to remove. Dropping drift at amplification
  16: time is cheaper than fetching and discarding.
  17: 
  18: DESIGN:
  19: - No new LLM call. Uses token overlap with protocol.research_question +
  20:   PICO fields (intervention / population / outcome) as the anchor.
  21: - Drops any amplified query whose Jaccard similarity with the anchor
  22:   is below PG_AMPLIFIER_SCOPE_FLOOR (default 0.15).
  23: - ALWAYS keeps the verbatim research_question and direct PICO-term
  24:   queries ("{intervention} {population}") as a safety net.
  25: - Logs drops so the user can see which amplifier variants were killed.
  26: """
  27: 
  28: from __future__ import annotations
  29: 
  30: import logging
  31: import os
  32: import re
  33: from dataclasses import dataclass
  34: from typing import Any, Optional
  35: 
  36: logger = logging.getLogger("polaris_graph.scope_query_validator")
  37: 
  38: 
  39: # Very small English stopword set — we care about domain terms, so
  40: # we strip only the grammatical connective tissue.
  41: _STOPWORDS = frozenset({
  42:     "a", "an", "and", "are", "as", "at", "be", "but", "by", "for", "from",
  43:     "has", "have", "in", "is", "it", "its", "of", "on", "or", "that",
  44:     "the", "this", "to", "was", "were", "will", "with", "what", "which",
  45:     "how", "why", "when", "where", "who", "whom", "whose", "i", "you",
  46:     "we", "they", "can", "could", "should", "would", "may", "might",
  47:     "do", "does", "did", "done", "being", "been", "about", "into",
  48:     "than", "then", "so", "also", "more", "most", "some", "any", "all",
  49:     "not", "no", "only", "very", "just", "other",
  50: })
  51: 
  52: _TOKEN_RE = re.compile(r"[A-Za-z][A-Za-z0-9\-]{1,}")
  53: 
  54: 
  55: def _tokenize(text: str) -> set[str]:
  56:     """Lowercased tokens minus stopwords, minus short tokens."""
  57:     if not text:
  58:         return set()
  59:     tokens = {
  60:         t.lower()
  61:         for t in _TOKEN_RE.findall(text)
  62:         if len(t) > 2
  63:     }
  64:     return tokens - _STOPWORDS
  65: 
  66: 
  67: def _jaccard(a: set[str], b: set[str]) -> float:
  68:     """Jaccard similarity. Empty a or b -> 0.0."""
  69:     if not a or not b:
  70:         return 0.0
  71:     union = a | b
  72:     inter = a & b
  73:     return len(inter) / len(union) if union else 0.0
  74: 
  75: 
  76: @dataclass
  77: class ValidationResult:
  78:     """Return value of validate_amplified_queries()."""
  79: 
  80:     kept: list[str]
  81:     dropped: list[tuple[str, float, str]]  # (query, similarity, reason)
  82:     anchor_tokens_used: list[str]
  83: 
  84: 
  85: def _build_anchor_tokens(protocol: dict[str, Any]) -> set[str]:
  86:     """Merge research_question + PICO tokens into one anchor set.
  87: 
  88:     Accepts either a ProtocolDocument dict (from scope_gate) or any
  89:     dict with similar fields. Missing fields are skipped gracefully.
  90:     """
  91:     bag: set[str] = set()
  92:     for field in (
  93:         "research_question", "population", "intervention",
  94:         "comparator", "outcome",
  95:     ):
  96:         val = protocol.get(field) or ""
  97:         bag |= _tokenize(str(val))
  98:     return bag
  99: 
 100: 
 101: def validate_amplified_queries(
 102:     amplified: list[str],
 103:     protocol: dict[str, Any],
 104:     *,
 105:     floor: Optional[float] = None,
 106:     always_keep_anchor: bool = True,
 107: ) -> ValidationResult:
 108:     """Drop amplified queries that drift off the scope protocol.
 109: 
 110:     Args:
 111:         amplified: Raw output from query amplifier — plain string queries.
 112:         protocol: Dict form of protocol.json, OR any dict with the
 113:             fields research_question / intervention / population / outcome.
 114:         floor: Minimum Jaccard similarity (tokens-vs-anchor-tokens) to
 115:             keep a query. Default: PG_AMPLIFIER_SCOPE_FLOOR env var,
 116:             fallback 0.15.
 117:         always_keep_anchor: When True, the verbatim research_question is
 118:             always kept even if its own Jaccard is below floor (which
 119:             can happen for very short questions). Default True.
 120: 
 121:     Returns:
 122:         ValidationResult with `kept` (queries that passed), `dropped`
 123:         (tuples with reason), and `anchor_tokens_used` for debugging.
 124:     """
 125:     if floor is None:
 126:         floor = float(os.getenv("PG_AMPLIFIER_SCOPE_FLOOR", "0.15"))
 127: 
 128:     anchor_tokens = _build_anchor_tokens(protocol)
 129:     anchor_tokens_sorted = sorted(anchor_tokens)
 130: 
 131:     research_question = (protocol.get("research_question") or "").strip()
 132: 
 133:     kept: list[str] = []
 134:     dropped: list[tuple[str, float, str]] = []
 135:     seen: set[str] = set()
 136: 
 137:     # Dedupe while preserving order
 138:     unique_amplified: list[str] = []
 139:     for q in amplified:
 140:         norm = (q or "").strip().lower()
 141:         if norm and norm not in seen:
 142:             seen.add(norm)
 143:             unique_amplified.append(q.strip())
 144: 
 145:     for q in unique_amplified:
 146:         q_tokens = _tokenize(q)
 147:         if not q_tokens:
 148:             dropped.append((q, 0.0, "empty_after_tokenization"))
 149:             continue
 150:         sim = _jaccard(q_tokens, anchor_tokens)
 151:         if sim >= floor:
 152:             kept.append(q)
 153:         else:
 154:             dropped.append((q, sim, f"below_scope_floor_{floor:.2f}"))
 155: 
 156:     # Safety net: always keep the verbatim research_question, even if
 157:     # its own similarity was below floor (happens for very short PICO
 158:     # questions like "Semaglutide efficacy?").
 159:     if always_keep_anchor and research_question:
 160:         if research_question not in kept:
 161:             kept.insert(0, research_question)
 162: 
 163:     logger.info(
 164:         "[scope_validator] floor=%.2f kept=%d dropped=%d (anchor_tokens=%d)",
 165:         floor, len(kept), len(dropped), len(anchor_tokens),
 166:     )
 167:     if dropped:
 168:         sample = dropped[:3]
 169:         for q, sim, reason in sample:
 170:             logger.debug(
 171:                 "[scope_validator] DROP q=%r sim=%.3f reason=%s",
 172:                 q[:80], sim, reason,
 173:             )
 174: 
 175:     return ValidationResult(
 176:         kept=kept,
 177:         dropped=dropped,
 178:         anchor_tokens_used=anchor_tokens_sorted,
 179:     )

