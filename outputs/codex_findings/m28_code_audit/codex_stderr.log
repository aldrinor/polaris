  80: # ─────────────────────────────────────────────────────────────────
  81: # BUG-B-101 fix: unified manifest.status taxonomy.
  82: #
  83: # Pre-fix, successful runs wrote manifest.json WITHOUT a "status" key
  84: # while abort runs DID include it. Documentation claimed
  85: # manifest.status was authoritative — it wasn't. See
  86: # outputs/codex_findings/deep_dive_round_1/findings.md for the full
  87: # scoping analysis.
  88: #
  89: # Post-fix, EVERY exit path writes a manifest.json with a "status"
  90: # field from this unified taxonomy. `summary["status"]` is preserved
  91: # as secondary sweep telemetry for backward compatibility with any
  92: # downstream counter that relied on the legacy labels.
  93: # ─────────────────────────────────────────────────────────────────
  94: 
  95: UNIFIED_STATUS_VALUES: frozenset[str] = frozenset({
  96:     # success
  97:     "success",
  98:     # partial — report produced but degraded signal
  99:     "partial_thin_corpus",
 100:     "partial_incomplete_corpus",
 101:     "partial_rule_check_warnings",
 102:     "partial_outline_fallback",      # BUG-M-203: planner failed, fallback used
 103:     "partial_qwen_advisory",         # BUG-M-205: Qwen judge flagged critical axes
 104:     # abort — pipeline refused to produce a report
 105:     "abort_scope_rejected",
 106:     "abort_no_sources",
 107:     "abort_corpus_inadequate",
 108:     "abort_corpus_approval_denied",
 109:     "abort_no_verified_sections",
 110:     "abort_evaluator_critical",      # BUG-M-205: PT08/PT11/PT12 integrity failure
 111:     # error — unhandled exception
 112:     "error_unexpected",
 113: })
 114: 
 115: # Map legacy summary["status"] labels → unified manifest.status values.
 116: _SUMMARY_TO_UNIFIED: dict[str, str] = {
 117:     "ok": "success",
 118:     "ok_thin_corpus": "partial_thin_corpus",
 119:     "ok_incomplete_corpus": "partial_incomplete_corpus",
 120:     "ok_outline_fallback": "partial_outline_fallback",
 121:     "ok_qwen_advisory": "partial_qwen_advisory",
 122:     "warn_rule_checks": "partial_rule_check_warnings",
 123:     "fail_no_sources": "abort_no_sources",
 124:     "fail_no_verified_prose": "abort_no_verified_sections",
 125:     "abort_scope_rejected": "abort_scope_rejected",
 126:     "abort_corpus_inadequate": "abort_corpus_inadequate",
 127:     "abort_corpus_approval_denied": "abort_corpus_approval_denied",
 128:     "abort_no_verified_sections": "abort_no_verified_sections",
 129:     "abort_evaluator_critical": "abort_evaluator_critical",
 130:     "error": "error_unexpected",
 131: }
 132: 
 133: 
 134: def to_unified_status(summary_status: str) -> str:
 135:     """Map a legacy summary["status"] label to the unified
 136:     manifest.status taxonomy. Unknown labels become error_unexpected
 137:     (fail loudly for the reader; still a valid taxonomy value)."""
 138:     return _SUMMARY_TO_UNIFIED.get(summary_status, "error_unexpected")
