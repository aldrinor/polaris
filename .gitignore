# ============================================================
# POLARIS .gitignore
# ============================================================

# --- Secrets ---
.env
.env.*
!.env.example
# Plan v13 §C HMAC key, GPG private keys, signed-PDF artifacts.
# PR-1 dryrun-iter-5 P1-001 fix: comment moved to its own line; trailing
# comment on the .private/ rule was being treated as part of the pattern,
# leaving .private/codex_hmac.key NOT ignored (cleanup_audit.md §3.6).
.private/

# --- Terraform (I-carney-002) ---
infra/aws/terraform.tfvars
infra/aws/.terraform/
infra/aws/.terraform.lock.hcl
infra/aws/*.tfstate
infra/aws/*.tfstate.*
infra/aws/plan.bin
!infra/aws/terraform.tfvars.example

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Test / Lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# --- Runtime / transient state ---
logs/
outputs/*
!outputs/codex_findings/
# Cycle-6 P2.3: tighten outputs/audits/ exemption to continuous/ only.
# Older outputs/audits/v25..v27 dirs are bloat (~1MB) — historical sweep
# stdouts that weren't meant to be tracked. continuous/ holds the durable
# A+C audit trail.
!outputs/audits/
!outputs/audits/continuous/
!outputs/audits/continuous/*.md
# PR-B (2026-05-05) per plan §9.5 + iter-2 PRB2-P1-003 fix:
# unignore durable state files needed at session boot.
# Runtime stamps + sqlite caches stay ignored.
state/*
!state/polaris_restart/
!state/polaris_restart/**
!state/polaris_statistical_contract/
!state/polaris_statistical_contract/**
!state/data_lineage/
!state/data_lineage/schemas/
!state/data_lineage/schemas/**
!state/data_lineage/code_pins.sha256
!state/active_issue.json
!state/restart_instructions.md
!state/handover.md
# Re-ignore session stamps + delete-failure logs (per-day ephemeral, never tracked)
state/polaris_restart/session_started_*.stamp
state/polaris_restart/cleanup_delete_failures.txt
# Cleanup-PR-1 manifest sidecars: track .gitkeep + .txt sidecars only
# (per PR1-DRYRUN iter 2 PR1-DRYRUN-iter2-P1-002 fix; iter 6 P2-001 narrowing).
# Line 55's broad `!state/polaris_restart/**` un-ignores everything; we
# narrow here by RE-ignoring all sidecar contents, then UN-ignoring only
# .gitkeep + *.txt patterns explicitly. Result: non-.txt/non-.gitkeep files
# in cleanup_manifest_sidecars/ stay ignored (won't be staged accidentally).
state/polaris_restart/cleanup_manifest_sidecars/*
!state/polaris_restart/cleanup_manifest_sidecars/.gitkeep
!state/polaris_restart/cleanup_manifest_sidecars/*.txt
# Re-ignore Codex verdict transcripts (per PR-B iter 6 PRB6-P2-002 fix):
# Verdicts are review-process artifacts kept under .codex/, not part of the
# durable polaris-restart substrate. Without this re-ignore, a future broad
# `git add state/polaris_restart` could sweep them in unintentionally.
state/polaris_restart/codex_verdict_*.txt
state/polaris_restart/*_verdict_iter_*.txt

# I-cd-014 (GH#610): real static_accounts.yaml MUST NOT be in repo.
# Operator provisions at /etc/polaris/static_accounts.yaml in deployment
# (see docs/carney_demo_runbook.md "Auth setup"). The .example file
# stays tracked as a template.
config/static_accounts.yaml

# --- Large trace files ---
*.jsonl
# Plan v13 §I exception: track durable audit logs + verdict trails.
!outputs/audits/*.jsonl
!outputs/audits/**/*.jsonl
!outputs/codex_findings/**/*.jsonl

# --- ML models (multi-GB) ---
models/
# I-cd-005: docs/models/ holds model-pick / quant / serving docs (text only,
# not weights). Negate the broad models/ rule for that specific docs subtree.
!docs/models/

# --- Archive (historical snapshots, 36 GB+) ---
archive/
# I-meta-001 (#933) exception: docs/archive/ holds superseded but historically-relevant
# decision documents that MUST stay tracked so the supersession chain is auditable.
!docs/archive/
!docs/archive/**

# --- ChromaDB vector store ---
memory/chroma_db/

# --- Claude config (Plan v13 §I selective tracking) ---
# Use `.claude/*` so unignore rules can selectively re-include children.
# IMPORTANT: settings.local.json STAYS IGNORED — it contains per-machine
# permission entries that may include API keys / secrets in Bash command
# allowlists (per Codex round-1 P0-1 finding 2026-05-02). Shared hook config
# lives in `.claude/settings.json` (no permissions, no secrets).
.claude/*
!.claude/hooks/
!.claude/hooks/**
!.claude/settings.json

# --- Node ---
node_modules/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
Thumbs.db
.DS_Store
nul

# --- Docker (local overrides only) ---
docker-compose.override.yml

# --- Transient screenshots at repo root ---
current_ui*.png

# --- Nested legacy copies ---
POLARIS_APEX/

# --- Sister admin-only repo (PR-B2 relocation 2026-05-05) ---
# polaris-controls is its own git repo (origin: aldrinor/polaris-controls).
# It lives under POLARIS root per user directive "everything inside polaris
# folder", but POLARIS does NOT track its files (they belong to the sister
# repo's own git history). The session-start hooks read CHARTER.md + PLAN.md
# from this directory via `git hash-object` for SHA pin verification.
polaris-controls/

# --- Data (benchmarks, documents — reproducible) ---
data/

# --- Accidental scratch dirs that accumulate at repo root ---
# These appeared during 2026-Q1 development and were archived
# on 2026-04-18. Block them from reappearing untracked.
tmp/
wiki/
cache/
loopback/

# --- Root-level audit/debug dumps ---
audit_*.txt
loopback_inspect_pages.txt

# --- Pytest / Codex review scratch dirs at repo root (I-hygiene-001 / #432) ---
# Anchored to repo root (leading `/`); directory-only (trailing `/`). These
# accumulate from pytest `tmp_path` basetemp leakage + `codex exec` review
# sandboxes and are pure throwaway. Verified 2026-05-17 against polaris HEAD:
# zero of these patterns shadow any git-tracked path.
/codex_tmp*/
/.codex_tmp*/
/codex_probe*/
/codex_gpg_probe*/
/tmp*/
/.tmp*/
/.pytest_*/
/pytest-cache-files-*/
/pytest_run_*/
/pytest_basetemp*/
/py_pytest_*/
/dashboard_probe_*/
/manual_pytest_*/
/manual_tmp_*/
/m_int_*_manual_*/
/m10v*/
/m_live_4_r2_*/
/md3_pytest_*/
/python_mode_*_probe/
/POLARIS.tmp*/
/POLARIStmp*/

# --- Codex loop ephemera ---
.codex/round_*/stdout.log
.codex/round_*/stderr.log
outputs/codex_findings/round_*/stdout.log
outputs/codex_findings/round_*/stderr.log
outputs/codex_findings/round_*/tmp_probe/
outputs/codex_findings/round_*/last_message.txt

# --- A+C continuous audit + cross-review artifacts (TRACKED) ---
# These are the durable Codex-as-subagent audit records produced under
# the per-K=5 triangle scheme. Paired with .codex/continuous/<sha>_*.md
# briefs they are the audit-trail for every shipped substrate commit.
!outputs/audits/
!outputs/audits/continuous/
!outputs/audits/continuous/*.md

# --- Plan v13 autoloop substrate (TRACKED) ---
# Per Plan v13 §I: per-task manifests, verdicts, briefs, attestations are
# all version-controlled artifacts under outputs/audits/. The .codex/verdicts
# path was an earlier draft; canonical location is outputs/audits/verdicts/.
!outputs/audits/manifests/
!outputs/audits/manifests/**
!outputs/audits/verdicts/
!outputs/audits/verdicts/**
!outputs/audits/briefs/
!outputs/audits/briefs/**
!outputs/audits/attestations/
!outputs/audits/attestations/**
!outputs/audits/halt_resolutions/
!outputs/audits/halt_resolutions/**

# --- Schemas (TRACKED) ---
!docs/schemas/
!docs/schemas/**

# --- GPG public keys (TRACKED) ---
!docs/keys/
!docs/keys/**

# --- Canonical pin (TRACKED) ---
!docs/canonical_pin.txt

# I-sec-001 (#535): raw codex-exec transcripts are NEVER committed — only the
# slim extracted verdict (codex_brief_verdict.txt / codex_diff_audit.txt). The
# CI codex-artifact-gate is the enforcement; this keeps local staging clean.
.codex/**/codex_*review*.txt
.codex/**/codex_diff_review*.txt
.codex/**/codex_brief_review*.txt
.codex/**/codex_brief_verdict_iter*.txt
.codex/**/codex_diff_audit_iter*.txt
.codex/*/codex_*review*.txt
.codex/*/codex_*_review_iter*.txt

# I-cd-012 (GH#608): canonical signed-bundle fixture content MUST be tracked
!tests/fixtures/signed_bundle/
!tests/fixtures/signed_bundle/**

# I-p2-p0 (#789): canonical demo bundles MUST ship to prod (read by the inspector). Never ignore.
!web/public/canonical_bundles/
!web/public/canonical_bundles/**
