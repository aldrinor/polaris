# Version control
.git
.gitignore

# Environment and secrets
.env
*.env.local
*.env.production
# I-cd-014 (GH#610): real static_accounts.yaml MUST NOT enter the Docker
# build context. Dockerfile.v6 does `COPY config/ config/`; without this
# exclusion any local copy gets baked into the image. The .example template
# is fine; the real file is mounted at /etc/polaris/ in deployment.
config/static_accounts.yaml

# Development artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# IDE
.vscode
.idea
*.swp
*.swo

# Archives and historical data
archive/
*.bak

# Large data files
outputs/
logs/
state/
data/

# Documentation (not needed in container)
docs/
*.md
!architecture.md
!ground_rules.md

# Tests (not needed in production container)
tests/

# Claude/AI config
.claude/

# Memory and project notes
memory/
POLARIS_APEX/
models/
