  "claim_requirements": {
    "_description": "Requirements before claiming SOTA status",

    "must_pass_all": [
      "sample_size >= 100",
      "win_rate > 50% with statistical significance (p < 0.05)",
      "wins on >= 3 of 5 core metrics",
      "reproducible with seed + config",
      "honest evaluation mode (no gaming)"
