# POLARIS SOTA Validation Framework - Honest Evaluation Configuration
# Created: 2026-02-05
# Purpose: Disable all gaming mechanisms for publication-grade evaluation
#
# This configuration removes all shortcuts and gaming mechanisms that inflate
# faithfulness scores. Use this for honest SOTA comparisons.

# =============================================================================
# CORE HONEST MODE FLAGS
# =============================================================================

# Master switch for honest evaluation mode
POLARIS_HONEST_MODE=1

# Disable soft pass threshold (was: 60% -> PASS)
# With this set to 0, only 70%+ faithfulness achieves PASS
POLARIS_SOFT_PASS=0

# Enable dual verification (sentence + atomic)
POLARIS_DUAL_VERIFICATION=1

# Require strict atomic verification (>= 50% atomic facts must pass)
POLARIS_STRICT_ATOMIC=1

# Disable safe harbor exemptions (count ALL claims)
POLARIS_NO_SAFE_HARBOR=1

# =============================================================================
# VERIFICATION THRESHOLDS (STRICT)
# =============================================================================

# MiniCheck confidence thresholds
# Default: 0.50 for pass. Strict: 0.70
POLARIS_SUPPORT_THRESHOLD=0.70

# Soft verify threshold disabled in strict mode
POLARIS_SOFT_VERIFY_THRESHOLD=0.70

# Atomic verification must pass this ratio
POLARIS_ATOMIC_PASS_RATIO=0.50

# =============================================================================
# FACTSCORE CONFIGURATION (REAL LLM DECOMPOSITION)
# =============================================================================

# Use LLM for atomic decomposition instead of heuristics
POLARIS_USE_LLM_DECOMPOSITION=1

# Disable heuristic atom counting
POLARIS_HEURISTIC_FACTSCORE=0

# =============================================================================
# FAITHFULNESS CALCULATION
# =============================================================================

# No default confidence (was: 0.3 default if verification fails)
POLARIS_DEFAULT_CONFIDENCE=0.0

# Require actual verification for all claims
POLARIS_REQUIRE_VERIFICATION=1

# Count uncited factual sentences as unfaithful
POLARIS_COUNT_UNCITED=1

# =============================================================================
# ESCALATION DISABLED (For clean measurement)
# =============================================================================

# Disable thinking escalation (measure MiniCheck directly)
POLARIS_THINKING_ESCALATION=0

# Disable LLM fallback for uncertain cases
POLARIS_LLM_FALLBACK=0

# =============================================================================
# LOGGING AND TRACING
# =============================================================================

# Enable verbose logging for audit trail
POLARIS_VERBOSE_AUDIT=1

# Log all verification decisions
POLARIS_LOG_VERIFICATIONS=1

# =============================================================================
# USAGE NOTES
# =============================================================================
#
# To run with honest evaluation:
#   1. Source this file: source config/evaluation_strict.env
#   2. Or set POLARIS_HONEST_MODE=1 and other flags will be auto-configured
#
# Expected impact:
#   - Faithfulness will DROP from ~97% to estimated 60-70%
#   - This reflects true performance, not gamed metrics
#   - Use this for publication-grade comparisons to SOTA baselines
#
# DO NOT use this for regular development iterations - use default config.
