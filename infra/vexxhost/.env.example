# I-carney-008 — POLARIS Vexxhost deploy .env template.
#
# Copy to /root/.env on the Vexxhost VM (NOT in repo — gitignored).
# All values are sensitive. Replace REPLACE_ME placeholders before scp.

# ---- LLM backend ----
# DEFAULT to openrouter for the transition window. The vLLM client lives in
# GH#199 I-sov-001 — DO NOT set POLARIS_LLM_BACKEND=vllm until that PR lands
# AND OVH BHS H200 is online (GH#90 I-phase0-009). Setting it now will break
# generation. /transparency surfaces this backend; reviewers see the US
# disclosure during the transition.
POLARIS_LLM_BACKEND=openrouter   # flip to "vllm" post-GH#199 + post-OVH-H200
POLARIS_VLLM_BASE_URL=http://10.0.0.42:8000/v1   # only used when backend=vllm
OPENROUTER_API_KEY=REPLACE_ME_OR_REMOVE_AFTER_VLLM_CUTOVER

# ---- Live retrieval ----
# Serper is the search backend. It is US-based and that is accepted per
# user directive 2026-05-13: search queries carry no confidential content,
# and the generated reports stay on sovereign infrastructure. Serper is
# disclosed plainly in /transparency §4. REQUIRED — runs fail loudly
# without it.
SERPER_API_KEY=REPLACE_ME
# Semantic Scholar is hosted by AI2 (US non-profit, public corpus). Disclosed
# in /transparency; remove for stricter sovereignty.
SEMANTIC_SCHOLAR_API_KEY=

# ---- Sovereign deploy provenance ----
# Surfaced by /transparency. Truthful disclosure is non-negotiable.
POLARIS_PROVIDER=vexxhost
POLARIS_REGION=montreal-qc

# ---- Auth (I-carney-004) ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
POLARIS_JWT_SECRET=REPLACE_ME_64_BYTE_URL_SAFE_RANDOM

# Path inside the container — provision.sh writes /etc/polaris/static_accounts.yaml
# and bind-mounts /etc/polaris into the container.
POLARIS_STATIC_ACCOUNTS_PATH=/etc/polaris/static_accounts.yaml
POLARIS_ETC_DIR=/etc/polaris

# ---- GPG bundle signing ----
# Fingerprint output by scripts/bootstrap_gpg_demo_key.sh.
POLARIS_GPG_KEY_ID=REPLACE_ME_FINGERPRINT
POLARIS_GPG_HOMEDIR=/var/lib/polaris/gpg

# ---- Pipeline-A controls ----
PG_MAX_COST_PER_RUN=5.00
POLARIS_GIT_COMMIT=REPLACE_ME_REPO_SHA

# ---- Compose port mapping ----
POLARIS_API_PORT=8000
POLARIS_WEB_PORT=3000

# ---- Egress allowlist override (optional) ----
POLARIS_EGRESS_ALLOWLIST=/etc/polaris/egress_allowlist.txt
