{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "polaris/safety/construction_manifest",
  "title": "construction_manifest",
  "description": "Per-claim construction metadata. STRUCTURAL exposure — contains NO labels (anti-leak per 0a.-1.A/0a.-1.C). One row per claim.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "scenario_id",
    "blinding_unit_id",
    "source_report_id",
    "domain",
    "complexity_tier",
    "evidence_pool_bin",
    "microtopic_tags",
    "sme_template_id",
    "constructor_sme_id",
    "construction_window_start",
    "generator_prompt_family_id",
    "verifier_prompt_family_id",
    "evidence_packet_id",
    "claim_cited_source_ids",
    "claim_entity_ids",
    "created_at"
  ],
  "properties": {
    "claim_id": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string", "minLength": 1},
    "blinding_unit_id": {"type": "string", "minLength": 1},
    "source_report_id": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "enum": ["clinical", "due_diligence", "policy", "tech", "ai_sovereignty", "canada_us"]},
    "complexity_tier": {"type": "string", "enum": ["C1", "C2", "C3"], "description": "D2 forward-dependency; enum finalized when D2 locks."},
    "evidence_pool_bin": {"type": "string", "enum": ["E1", "E2", "E3", "E4"], "description": "D3 forward-dependency."},
    "microtopic_tags": {"type": "array", "items": {"type": "string"}, "description": "D4 microtopic ids; criterion-5 input."},
    "sme_template_id": {"type": "string", "minLength": 1, "description": "D6 forward; criterion-3 input."},
    "constructor_sme_id": {"type": "string", "minLength": 1},
    "construction_window_start": {"type": "integer", "description": "UTC epoch seconds; criterion-3 24h window."},
    "generator_prompt_family_id": {"type": "string", "minLength": 1, "description": "D5 forward; criterion-4 input."},
    "verifier_prompt_family_id": {"type": "string", "minLength": 1, "description": "D5 forward; criterion-4 input."},
    "evidence_packet_id": {"type": "string", "minLength": 1},
    "claim_cited_source_ids": {"type": "array", "items": {"type": "string"}, "description": "Alias-resolved canonical_source_id values (0a.-1.D); claim-level set for criterion-2/5 Jaccard."},
    "claim_entity_ids": {"type": "array", "items": {"type": "string"}, "description": "0a.-1.D §5: source_entities ∪ claim_subject_entities, for COI."},
    "created_at": {"type": "string", "format": "date-time"},
    "retrieved_source_count": {"type": "integer", "minimum": 0, "description": "D3 §3: full production-retrieval admissible-source count before downselect. STRUCTURAL (pre-outcome). Optional; present when downselect occurred."},
    "target_packet_source_count": {"type": "integer", "minimum": 1, "maximum": 80, "description": "D3 §3: the N downselected to (<=80), recorded BEFORE downselect. STRUCTURAL. Optional; present when downselect occurred."}
  }
}
