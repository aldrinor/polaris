{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "polaris/safety/source_packet_manifest",
  "title": "source_packet_manifest",
  "description": "Per-packet evidence record (0a.-1.D). One row per evidence_packet_id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence_packet_id", "canonical_source_ids", "packet_class", "sha256_of_sorted_canonical_ids"],
  "properties": {
    "evidence_packet_id": {"type": "string", "minLength": 1},
    "canonical_source_ids": {"type": "array", "items": {"type": "string"}, "description": "Alias-resolved canonical_source_id values; source-document-level set."},
    "packet_class": {"type": "string", "minLength": 1, "description": "Criterion-5 shared-packet-class input (0a.-1.D)."},
    "sha256_of_sorted_canonical_ids": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
